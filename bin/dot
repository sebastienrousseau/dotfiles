_dot_command_route() {
  local command_name="${1:-}"
  if [[ -z "$command_name" ]]; then
    return 1
  fi
  awk -F'|' -v command_name="$command_name" '$1 == command_name { print $2; exit }' < <(_dot_command_routes)
}

show_help_overview() {
  ui_dot_banner "Reference"
  ui_header "Dotfiles"
  ui_meta "Usage" "dot [command]"
  ui_meta "Version" "v$VERSION"
  echo ""

  ui_info "What it is" "A single command for setting up, checking, and maintaining this shell environment."
  ui_info "Platforms" "macOS, Linux, and WSL"
  ui_info "Start" "Run 'dot sync', then 'dot doctor', then 'dot learn'"
  echo ""

  local current_section="" section="" command_name="" description="" detail=""
  while IFS='|' read -r section command_name description detail; do
    if [[ "$section" != "$current_section" ]]; then
      if [[ -n "$current_section" ]]; then
        echo ""
      fi
      ui_section "$section"
      current_section="$section"
    fi
    ui_cmd "$command_name" "$description"
  done < <(_dot_help_overview_specs)
  echo ""
  ui_info "Next" "Run 'dot help all' for the full command list"
  ui_info "Detail" "Run 'dot help <command>' for one command"
}

show_help_all() {
  ui_dot_banner "Reference"
  ui_header "Dotfiles Command Reference"
  ui_meta "Usage" "dot [command]"
  ui_meta "Version" "v$VERSION"
  echo ""

  local current_section="" section="" command_name="" description="" detail=""
  while IFS='|' read -r section command_name description detail; do
    if [[ "$command_name" == "help all" ]]; then
      continue
    fi
    if [[ "$section" != "$current_section" ]]; then
      if [[ -n "$current_section" ]]; then
        echo ""
      fi
      ui_section "$section"
      current_section="$section"
    fi
    ui_cmd "$command_name" "$description"
  done < <(_dot_help_specs)
}

show_help_command() {
  local command_name="${1:-}"
  local normalized summary examples

  normalized="$command_name"
  if [[ "$command_name" == "version" || "$command_name" == "-v" ]]; then
    normalized="--version"
  fi

  summary="$(_dot_help_summary "$normalized")"
  examples="$(_dot_help_examples "$normalized")"

  if [[ -z "$summary" ]]; then
    ui_fail "Unknown help topic: $command_name"
    ui_info "Hint" "Try 'dot help all' or 'dot search <keyword>'"
    exit 1
  fi

  ui_dot_banner "Reference"
  ui_header "dot $command_name"
  echo ""
  ui_info "Summary" "$summary"
  if [[ -n "$examples" ]]; then
    echo ""
    ui_section "Examples"
    while IFS= read -r example; do
      [[ -n "$example" ]] || continue
      ui_cmd "$example" ""
    done < <(printf '%b\n' "$examples")
  fi
}

show_help() {
  local topic="${1:-}"
  case "$topic" in
    "")
      show_help_overview
      ;;
    all)
      show_help_all
      ;;
    *)
      show_help_command "$topic"
      ;;
  esac
}

resolve_source_dir() { _resolve_source_dir; }

# ─── Dispatcher ───────────────────────────────────────────────────────────────
# Routes COMMAND to the appropriate command module in scripts/dot/commands/.
# Each module receives the original COMMAND as its first argument so that its
# internal case statement can dispatch to the right sub-function.
_SOURCE_DIR="$(_resolve_source_dir)"
_CMD_DIR="${_SOURCE_DIR}/scripts/dot/commands"

_dispatch() {
  local module="$1"
  shift # remove module name; remaining $@ are the user's extra args
  local cmd_file="${_CMD_DIR}/${module}.sh"
  if [[ -f "$cmd_file" ]]; then
    # shellcheck disable=SC1090
    exec bash "$cmd_file" "$COMMAND" "$@"
  else
    ui_fail "Command module not found: $cmd_file"
    exit 1
  fi
}

if [[ -z "$COMMAND" ]]; then
  show_help
  exit 0
fi

# `|| true` is intentional: an unknown command yields an empty route, which falls
# through the case below into the user-command path that emits the proper error.
route="$(_dot_command_route "$COMMAND" || true)"

case "$route" in
  core | diagnostics | ai | tools | appearance | secrets | security | meta | fleet)
    _dispatch "$route" "$@"
    ;;

  agents)
    if [[ -n "$_SOURCE_DIR" ]] && [[ -f "$_SOURCE_DIR/scripts/dot/commands/agents.sh" ]]; then
      # shellcheck disable=SC1091
      source "$_SOURCE_DIR/scripts/dot/commands/agents.sh"
      cmd_agents "$@"
      exit $?
    else
      ui_fail "agents.sh not found"
      exit 1
    fi
    ;;

  init)
    if [[ -n "$_SOURCE_DIR" ]] && [[ -f "$_SOURCE_DIR/scripts/dot/commands/init.sh" ]]; then
      # shellcheck disable=SC1091
      source "$_SOURCE_DIR/scripts/dot/commands/init.sh"
      cmd_init "$@"
      exit $?
    else
      ui_fail "init.sh not found"
      exit 1
    fi
    ;;

  registry)
    if [[ -n "$_SOURCE_DIR" ]] && [[ -f "$_SOURCE_DIR/scripts/dot/commands/registry.sh" ]]; then
      # shellcheck disable=SC1091
      source "$_SOURCE_DIR/scripts/dot/commands/registry.sh"
      cmd_registry "$@"
      exit $?
    else
      ui_fail "registry.sh not found"
      exit 1
    fi
    ;;

  manual)
    if [[ -n "$_SOURCE_DIR" ]] && [[ -f "$_SOURCE_DIR/scripts/dot/commands/manual.sh" ]]; then
      exec bash "$_SOURCE_DIR/scripts/dot/commands/manual.sh" "$@"
    else
      ui_fail "manual.sh not found"
      exit 1
    fi
    ;;

  patterns)
    if [[ -n "$_SOURCE_DIR" ]] && [[ -f "$_SOURCE_DIR/scripts/dot/commands/patterns.sh" ]]; then
      exec bash "$_SOURCE_DIR/scripts/dot/commands/patterns.sh" "$@"
    else
      ui_fail "patterns.sh not found"
      exit 1
    fi
    ;;

  search)
    keyword="${1:-}"
    if [[ -z "$keyword" ]]; then
      echo "Usage: dot search <keyword>"
      exit 1
    fi
    show_help_all | grep -i --color=auto "$keyword" || echo "No commands matching '$keyword'"
    exit 0
    ;;

  help)
    show_help "$@"
    ;;

  version)
    show_version
    ;;

  # User-provided custom commands
  *)
    _user_cmd="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/commands/${COMMAND}.sh"
    if [[ -f "$_user_cmd" ]]; then
      # Run in a subshell so a user `exit` doesn't kill the dot CLI.
      (source "$_user_cmd" "$@")
      exit $?
    else
      echo "Unknown command: ${COMMAND:-}" >&2
      echo "Run 'dot help' for available commands." >&2
      exit 1
    fi
    ;;
esac
