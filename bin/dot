_dot_help_summary() {
  local command_name="${1:-}"
  awk -F'|' -v command_name="$command_name" '$1 == command_name { print $2; exit }' < <(_dot_help_details)
}

_dot_help_examples() {
  local command_name="${1:-}"
  awk -F'|' -v command_name="$command_name" '$1 == command_name { print $3; exit }' < <(_dot_help_details)
}

