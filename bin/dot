#!/usr/bin/env bash
# shellcheck disable=SC2034
# SPDX-License-Identifier: MIT
# Copyright (c) 2015-2026 Sebastien Rousseau
set -euo pipefail

# Dotfiles CLI Entry Point - v0.2.506

# Ensure XDG Base Directory variables are set
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Ensure PIPX paths are set
export PIPX_HOME="${XDG_DATA_HOME}/pipx"
export PIPX_BIN_DIR="${HOME}/.local/bin"

# Ensure Nix is in PATH if installed
if [ -e "${HOME}/.nix-profile/etc/profile.d/nix.sh" ]; then
  # shellcheck disable=SC1091
  . "${HOME}/.nix-profile/etc/profile.d/nix.sh"
fi

VERSION="0.2.506"

COMMAND="${1:-}"
if [ -n "${1:-}" ]; then
  shift
fi

# Resolve source directory (needed early for ui.sh sourcing)
_resolve_source_dir() {
  local dir=""
  local script_path=""
  local script_dir=""
  local repo_candidate=""

  if script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd 2>/dev/null)"; then
    script_dir="$script_path"
    # Post-v0.2.506: the canonical dispatcher lives at <repo>/bin/dot, so
    # $script_dir/.. is the repo root. Pre-v0.2.506 (and chezmoi-deployed
    # wrapper invocations that still exec the canonical) the dispatcher
    # was at <repo>/dot_local/bin/executable_dot, so $script_dir/../..
    # was the repo. Probe both to cover the transition.
    for candidate in "$script_dir/.." "$script_dir/../.."; do
      repo_candidate="$(cd "$candidate" && pwd 2>/dev/null || true)"
      if [ -n "$repo_candidate" ] && [ -f "$repo_candidate/lib/dot/ui.sh" ]; then
        dir="$repo_candidate"
        break
      fi
    done
  fi

  if [ -z "$dir" ] && [ -n "${CHEZMOI_SOURCE_DIR:-}" ] && [ -d "$CHEZMOI_SOURCE_DIR" ]; then
    dir="$CHEZMOI_SOURCE_DIR"
  elif [ -z "$dir" ] && [ -d "$HOME/.dotfiles" ]; then
    dir="$HOME/.dotfiles"
  elif [ -z "$dir" ] && [ -d "$HOME/.local/share/chezmoi" ]; then
    dir="$HOME/.local/share/chezmoi"
  elif [ -z "$dir" ] && [ -f "package.json" ] && grep -q '"name": "dotfiles"' package.json 2>/dev/null; then
    dir="$(pwd)"
  fi
  echo "$dir"
}

# Source shared UI library for consistent colors, checkmarks, and formatting.
# Falls back to minimal inline definitions if the source directory is unavailable.
_DOT_SRC="$(_resolve_source_dir)"
if [ -n "$_DOT_SRC" ] && [ -f "$_DOT_SRC/lib/dot/ui.sh" ]; then
  # shellcheck source=../../lib/dot/ui.sh
  # shellcheck disable=SC1091
  source "$_DOT_SRC/lib/dot/ui.sh"
  ui_init
else
  # Minimal fallback when source dir is not available (e.g. first install)
  # shellcheck disable=SC2034
  UI_COLOR=0
  BOLD=""
  NORMAL=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  CYAN=""
  GRAY=""
  MAGENTA=""
  ui_init() {
    if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
      UI_COLOR=1
      BASH_BOLD=$'\033[1m'
      NORMAL=$'\033[0m'
      RED=$'\033[38;5;196m'
      GREEN=$'\033[38;5;42m'
      YELLOW=$'\033[38;5;214m'
      BLUE=$'\033[38;5;63m'
      CYAN=$'\033[38;5;81m'
      GRAY=$'\033[38;5;244m'
      MAGENTA=$'\033[38;5;211m'
    fi
  }
  ui_header() {
    ui_init
    printf "\n  %s%s%s\n\n" "${BOLD}${BLUE}" "$1" "$NORMAL"
  }
  ui_section() {
    ui_init
    printf "  %s%s%s\n" "${BOLD}${CYAN}" "$1" "$NORMAL"
  }
  ui_cmd() {
    ui_init
    printf "  %s•%s %s%-16s%s %s\n" "$GREEN" "$NORMAL" "$GREEN" "$1" "$NORMAL" "$2"
  }
  ui_ok() {
    ui_init
    printf "  %s✓%s %-35s %s\n" "$GREEN" "$NORMAL" "$1" "${2:-}"
  }
  ui_info() {
    ui_init
    printf "  %s•%s %-35s %s\n" "$GRAY" "$NORMAL" "$1" "${2:-}"
  }
  ui_meta() {
    ui_init
    printf "  %s•%s %-14s %s\n" "$GRAY" "$NORMAL" "$1" "${2:-}"
  }
  ui_kv() {
    ui_init
    printf "  %s%-14s%s %s\n" "$BOLD" "$1" "$NORMAL" "$2"
  }
  ui_warn() {
    ui_init
    printf "  %s⚠%s %-35s %s\n" "$YELLOW" "$NORMAL" "$1" "${2:-}"
  }
  ui_err() {
    ui_init
    printf "  %s✗%s %-35s %s\n" "$RED" "$NORMAL" "$1" "${2:-}" >&2
  }
  ui_clear_line() { printf '\r\033[K'; }
  ui_toast() { case "$1" in success | ok) ui_ok "$2" ;; error | err) ui_err "$2" ;; warn) ui_warn "$2" ;; *) ui_info "$2" ;; esac }
fi

# Alias ui_fail → ui_err for backward compatibility in this script
ui_fail() { ui_err "$@"; }

ui_dot_banner() {
  local section="${1:-Dot}"
  if declare -F ui_product_banner >/dev/null 2>&1; then
    ui_product_banner "Dot • $section"
    return 0
  fi
  if declare -F ui_logo_dot >/dev/null 2>&1; then
    ui_logo_dot "Dot • $section"
  fi
}

show_version() {
  ui_dot_banner "Reference"
  ui_header "Dotfiles Version"
  echo ""
  ui_ok "Version" ".dotfiles $VERSION"
  if [[ -n "$_DOT_SRC" ]]; then
    ui_ok "Source" "$_DOT_SRC"
  fi
}

