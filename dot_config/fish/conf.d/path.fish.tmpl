# Construct PATH hierarchy for all language runtimes and tools.
# Sets PATH precedence: Local bin > Language runtimes > Homebrew > System.

# 1. System Paths (Prepend, but will be pushed down by later prepends)
fish_add_path /usr/bin /bin /usr/sbin /sbin

# 2. Homebrew Paths
fish_add_path /opt/homebrew/sbin
fish_add_path /opt/homebrew/bin

# 3. Language Runtimes
# Ruby
fish_add_path /opt/homebrew/opt/ruby/bin
fish_add_path "$HOME/.gem/ruby/bin"

# Python (Pipx)
set -gx PIPX_HOME (set -q XDG_DATA_HOME; and echo "$XDG_DATA_HOME"; or echo "$HOME/.local/share")/pipx
set -gx PIPX_BIN_DIR (set -q XDG_BIN_HOME; and echo "$XDG_BIN_HOME"; or echo "$HOME/.local/bin")
fish_add_path "$PIPX_BIN_DIR"

# Rust (Cargo)
fish_add_path "$HOME/.cargo/bin"

# Go
fish_add_path "$HOME/go/bin"

# Bun
set -gx BUN_INSTALL "$HOME/.bun"
fish_add_path "$BUN_INSTALL/bin"

# Node.js (Global)
fish_add_path "$HOME/.node_modules/bin"

# Lua (Luarocks)
fish_add_path "$HOME/.luarocks/bin"

# 4. Applications (macOS Specifics)
{{- if eq .chezmoi.os "darwin" }}
fish_add_path /Library/Apple/usr/bin
fish_add_path /Library/TeX/texbin
fish_add_path "/Applications/Topaz Photo AI.app/Contents/Resources/bin"
fish_add_path "/Applications/Little Snitch.app/Contents/Components"
fish_add_path "/Applications/iTerm.app/Contents/Resources/utilities"
fish_add_path "/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
{{- end }}

# 5. Local Bin (Highest Priority)
fish_add_path "$HOME/.local/bin"
fish_add_path "$HOME/.local/share/mise/shims"
fish_add_path "$HOME/bin"
