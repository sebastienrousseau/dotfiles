# Tool Initialization
if status is-interactive
    set -l SHELL_CACHE "$XDG_CACHE_HOME"
    if test -z "$SHELL_CACHE"
        set SHELL_CACHE "$HOME/.cache"
    end
    set SHELL_CACHE "$SHELL_CACHE/fish"
    mkdir -p "$SHELL_CACHE"

    function _cached_eval
        set -l label $argv[1]
        set -l cache "$SHELL_CACHE/$label.fish"
        set -l bin_name $argv[2]
        set -l bin (type -p $bin_name)

        if test -f "$cache"
            if test -z "$bin"; or test "$cache" -nt "$bin"
                source "$cache"
                return
            end
        end

        # Run the command and cache its output
        set -l cmd $argv[2..-1]
        $cmd >"$cache" 2>/dev/null
        source "$cache"
    end

    # Mise (Universal Version Manager)
    if command -v mise >/dev/null
        _cached_eval mise-init mise activate fish
    end

    # Atuin (Memory Layer)
    if command -v atuin >/dev/null
        _cached_eval atuin-init atuin init fish
    end

    # Starship Prompt (High Performance)
    if command -v starship >/dev/null
        _cached_eval starship-init starship init fish
    end

    # Zoxide (Smart Directory Jumper) - Replaces 'cd'
    if command -v zoxide >/dev/null
        _cached_eval zoxide-init zoxide init fish
    end

    # Pueue Daemon (Background Task Manager)
    if command -v pueue >/dev/null; and not pueue status >/dev/null 2>&1
        if command -v pueued >/dev/null
            pueued -d >/dev/null 2>&1
        end
    end

    # FZF (Fuzzy Finder)
    if command -v fzf >/dev/null
        _cached_eval fzf-init fzf --fish
    end
end
