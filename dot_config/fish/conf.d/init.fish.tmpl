# Tool Initialization
if status is-interactive
    # Mise (Universal Version Manager)
    if command -v mise >/dev/null
        mise activate fish | source
    end

    # Atuin (Memory Layer)
    if command -v atuin >/dev/null
        atuin init fish | source
    end

    # Starship Prompt (High Performance)
    if command -v starship >/dev/null
        starship init fish | source
    end

    # Zoxide (Smart Directory Jumper) - Replaces 'cd'
    if command -v zoxide >/dev/null
        zoxide init fish | source
    end

    # Pueue Daemon (Background Task Manager)
    if command -v pueue >/dev/null; and not pueue status >/dev/null 2>&1
        if command -v pueued >/dev/null
            pueued -d >/dev/null 2>&1
        end
    end

    # FZF (Fuzzy Finder)
    if command -v fzf >/dev/null
        fzf --fish | source
    end
end
