# рџ…ірџ…ңрџ†ѓрџ…µрџ…ёрџ…»рџ…өрџ†‚ (v{{ .dotfiles_version }}) вЂ” Interactive initialization
# Consolidated: init + keybindings + modern-core + carapace
# Non-interactive shells skip this entire file.

if not status is-interactive
    return
end

# в”Ђв”Ђ Shell Cache в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
set -g SHELL_CACHE "$XDG_CACHE_HOME"
if test -z "$SHELL_CACHE"
    set SHELL_CACHE "$HOME/.cache"
end
set SHELL_CACHE "$SHELL_CACHE/fish"
mkdir -p "$SHELL_CACHE"

# в”Ђв”Ђ Artifact Mode в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if not set -q DOTFILES_ARTIFACT_MODE
    set -gx DOTFILES_ARTIFACT_MODE 0
end

if test "$DOTFILES_ARTIFACT_MODE" = "1"
    function fish_prompt
        set_color green
        echo -n "вһњ "
        set_color normal
    end
    function fish_right_prompt; end
    set -g fish_greeting ""
end

# в”Ђв”Ђ Starship (eager вЂ” must survive cache clears) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if test "$DOTFILES_ARTIFACT_MODE" = "0"; and command -v starship >/dev/null
    starship init fish | source
end

# в”Ђв”Ђ Lazy Hydration (deferred to first prompt) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
function _dotfiles_async_init
    # Mise
    if command -v mise >/dev/null
        _cached_eval mise activate fish
    end
    # Atuin
    if command -v atuin >/dev/null
        _cached_eval atuin init fish
    end
    # Zoxide (--cmd=cd replaces cd with zoxide-aware version)
    if command -v zoxide >/dev/null
        _cached_eval zoxide init --cmd=cd fish
    end
    # FZF
    if command -v fzf >/dev/null
        _cached_eval fzf --fish
    end
    # Carapace completions (cached)
    if command -v carapace >/dev/null 2>&1
        _cached_eval carapace _carapace fish
    end
    # Pueue daemon (deferred here to avoid blocking shell startup)
    if command -v pueue >/dev/null; and not pueue status >/dev/null 2>&1
        if command -v pueued >/dev/null
            pueued -d >/dev/null 2>&1
        end
    end
end

function _dotfiles_trigger_hydration --on-event fish_prompt
    functions -e _dotfiles_trigger_hydration
    _dotfiles_async_init
    if test "$DOTFILES_ARTIFACT_MODE" = "1"
        begin
            bash "$HOME/.dotfiles/scripts/dot/lib/bento.sh" </dev/null
            kill -WINCH $fish_pid
        end &
    end
end

# в”Ђв”Ђ Keybindings (Fish 4.x enhanced) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
bind ctrl-backspace backward-kill-word
bind alt-enter 'commandline -f accept-autosuggestion; commandline -f execute'
bind ctrl-z undo
bind ctrl-shift-z redo
bind alt-up 'prevd; commandline -f repaint'
bind alt-down 'nextd; commandline -f repaint'
bind ctrl-left backward-word
bind ctrl-right forward-word
bind alt-l 'echo; ls; commandline -f repaint'
bind alt-. history-token-search-backward
bind ctrl-g 'echo; git status --short 2>/dev/null || echo "Not a git repo"; commandline -f repaint'
bind alt-e edit_command_buffer
if command -q fzf
    bind ctrl-t 'set -l result (fzf --height 40% --reverse 2>/dev/null); and commandline -it -- $result; commandline -f repaint'
end
