# Tool Initialization
if status is-interactive
    set -g SHELL_CACHE "$XDG_CACHE_HOME"
    if test -z "$SHELL_CACHE"
        set SHELL_CACHE "$HOME/.cache"
    end
    set SHELL_CACHE "$SHELL_CACHE/fish"
    mkdir -p "$SHELL_CACHE"

    # ==============================================================================
    # Dotfiles 2026: Zero-Jank & Artifact-Only Mode Foundation
    # ==============================================================================
    if not set -q DOTFILES_ARTIFACT_MODE
        set -gx DOTFILES_ARTIFACT_MODE 0
    end

    if test "$DOTFILES_ARTIFACT_MODE" = "1"
        # The Canvas: Strip away all visual noise.
        function fish_prompt
            set_color green
            echo -n "вћњ "
            set_color normal
        end
        function fish_right_prompt; end
        set -g fish_greeting ""
    end
    # ==============================================================================

    function _dotfiles_async_init
        # Mise
        if command -v mise >/dev/null
            set -l cache "$SHELL_CACHE/mise-init.fish"
            if not test -f "$cache"
                command mise activate fish > "$cache" </dev/null 2>/dev/null &
            end
            test -f "$cache"; and source "$cache"
        end

        # Atuin
        if command -v atuin >/dev/null
            set -l cache "$SHELL_CACHE/atuin-init.fish"
            if not test -f "$cache"
                command atuin init fish > "$cache" </dev/null 2>/dev/null &
            end
            test -f "$cache"; and source "$cache"
        end

        # Starship (Skip in Artifact Mode)
        if test "$DOTFILES_ARTIFACT_MODE" = "0"; and command -v starship >/dev/null
            set -l cache "$SHELL_CACHE/starship-init.fish"
            if not test -f "$cache"
                command starship init fish > "$cache" </dev/null 2>/dev/null &
            end
            test -f "$cache"; and source "$cache"
        end

        # Zoxide
        if command -v zoxide >/dev/null
            set -l cache "$SHELL_CACHE/zoxide-init.fish"
            if not test -f "$cache"
                command zoxide init fish > "$cache" </dev/null 2>/dev/null &
            end
            test -f "$cache"; and source "$cache"
        end

        # FZF
        if command -v fzf >/dev/null
            set -l cache "$SHELL_CACHE/fzf-init.fish"
            if not test -f "$cache"
                command fzf --fish > "$cache" </dev/null 2>/dev/null &
            end
            test -f "$cache"; and source "$cache"
        end
    end

    # Lazy-Hydration: Trigger on first prompt
    function _dotfiles_trigger_hydration --on-event fish_prompt
        functions -e _dotfiles_trigger_hydration
        _dotfiles_async_init
        if test "$DOTFILES_ARTIFACT_MODE" = "1"
           # Run bento and then trigger a prompt redraw
           begin
             bash "$HOME/.dotfiles/scripts/dot/lib/bento.sh" </dev/null
             kill -WINCH $fish_pid
           end &
        end
    end

    # Pueue Daemon (Background Task Manager)
    if command -v pueue >/dev/null; and not pueue status >/dev/null 2>&1
        if command -v pueued >/dev/null
            pueued -d >/dev/null 2>&1
        end
    end
end
