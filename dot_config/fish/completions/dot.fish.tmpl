# Appearance
complete -c dot -n "__fish_use_subcommand" -a theme -d "Switch terminal theme (dark/light)"
complete -c dot -n "__fish_use_subcommand" -a wallpaper -d "Apply a wallpaper"
complete -c dot -n "__fish_use_subcommand" -a fonts -d "Install Nerd Fonts"

# Secrets & Security
complete -c dot -n "__fish_use_subcommand" -a secrets-init -d "Initialize age key for secrets"
complete -c dot -n "__fish_use_subcommand" -a secrets -d "Edit encrypted secrets"
complete -c dot -n "__fish_use_subcommand" -a bundle -d "Create offline archive"
