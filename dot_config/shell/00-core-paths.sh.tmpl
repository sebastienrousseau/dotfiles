#!/usr/bin/env bash
## Construct PATH hierarchy for all language runtimes and tools.
##
## Sets PATH precedence: Local bin > Language runtimes > Homebrew > System.
## This file is generated by Chezmoi and should not be edited directly.
##
## # Data Flow
## ~/.zshenv (XDG vars) → 00-core-paths.sh (PATH) → tool-specific init
##
## # Platform Notes
## ### Platform: macOS
## - Adds /opt/homebrew/bin for Apple Silicon
## - Includes macOS application paths (VS Code, Little Snitch)
##
## ### Platform: Linux
## - Homebrew section skipped if /opt/homebrew absent
## - Standard FHS paths (/usr/bin, /usr/local/bin)
##
## ### Platform: WSL
## - Works with both Linux and Windows paths
## - Windows PATH inherited via interop
##
## # Dependencies
## - Bash 4+ for associative array PATH deduplication
## - Falls back to awk for Bash 3.x
##
## # Idempotency
## Safe to source multiple times. Deduplicates PATH entries.

# Helper: prepend path if directory exists (moves to front if already present)
path_prepend() {
    local dir="$1"
    [[ -n "$dir" && -d "$dir" ]] || return 0
    # Remove existing entry (if any) then prepend — ensures correct precedence
    PATH="${PATH/#"$dir:"/}"        # leading
    PATH="${PATH/%":$dir"/}"        # trailing
    PATH="${PATH//":$dir:"/:}"      # middle
    [[ "$PATH" == "$dir" ]] && PATH=""  # sole entry
    PATH="$dir${PATH:+:$PATH}"
}

# 1. System Paths (Prepend, but will be pushed down by later prepends)
PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH}"

# 2. Homebrew Paths (Prepend -> Higher Priority)
path_prepend "/opt/homebrew/sbin"
path_prepend "/opt/homebrew/bin"

# 3. Language Runtimes
# Ruby (Homebrew)
path_prepend "/opt/homebrew/opt/ruby/bin"
# Ruby (User Gems)
path_prepend "${HOME}/.gem/ruby/bin"

# Python (Pipx)
export PIPX_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/pipx"
export PIPX_BIN_DIR="${XDG_BIN_HOME:-$HOME/.local/bin}"
path_prepend "${PIPX_BIN_DIR}"

# .NET Tools
path_prepend "${HOME}/.dotnet/tools"

# Rust (Cargo)
path_prepend "${HOME}/.cargo/bin"

# Go
path_prepend "${HOME}/go/bin"

# Bun
export BUN_INSTALL="${HOME}/.bun"
path_prepend "${BUN_INSTALL}/bin"

# Kubeconfig merge logic (merge all configs in ~/.kube/config.d/)
# Lazy-loaded via kubectl wrapper to avoid startup cost
_lazy_load_kubeconfig() {
    if [[ -d "${HOME}/.kube/config.d" ]]; then
        local kubeconfig_extra=""
        for conf in "${HOME}/.kube/config.d"/*; do
            [[ -f "$conf" ]] && kubeconfig_extra="${kubeconfig_extra}:${conf}"
        done
        [[ -n "$kubeconfig_extra" ]] && export KUBECONFIG="${HOME}/.kube/config${kubeconfig_extra}"
    fi
    unset -f kubectl _lazy_load_kubeconfig 2>/dev/null
    command kubectl "$@"
}
# Only wrap kubectl if config.d exists and kubectl is installed
if [[ -d "${HOME}/.kube/config.d" ]]; then
    kubectl() { _lazy_load_kubeconfig "$@"; }
fi
# Still honor explicit KUBECONFIG or in-cluster detection
if [[ -n "${KUBERNETES_SERVICE_HOST:-}" ]] || [[ -n "${KUBECONFIG:-}" ]]; then
    _lazy_load_kubeconfig --version >/dev/null 2>&1 || true
fi

# Node.js (Global)
path_prepend "${HOME}/.node_modules/bin"

# Lua (Luarocks)
path_prepend "${HOME}/.luarocks/bin"

# 4. macOS System Paths
{{- if eq .chezmoi.os "darwin" }}
path_prepend "/Library/Apple/usr/bin"
{{- end }}

# 5. Local Bin and Tools (Highest Priority)
path_prepend "${HOME}/.fzf/bin"
path_prepend "${HOME}/.local/bin"
path_prepend "${HOME}/.local/share/mise/shims"
path_prepend "${HOME}/bin"

# Deduplicate PATH (Keep first occurrence to maintain precedence)
# Standard Zsh handles this with 'typeset -U path', but for bash compatibility/subshells:
if [ -z "${ZSH_VERSION:-}" ]; then
    # Use native bash associative arrays for O(n) deduplication (bash 4+)
    if [[ ${BASH_VERSION%%.*} -ge 4 ]]; then
        declare -A _seen_paths
        IFS=':' read -ra _path_array <<< "$PATH"
        _new_path=""
        for _dir in "${_path_array[@]}"; do
            if [[ -n "$_dir" && -z "${_seen_paths[$_dir]:-}" ]]; then
                _seen_paths[$_dir]=1
                _new_path="${_new_path:+$_new_path:}$_dir"
            fi
        done
        PATH="$_new_path"
        unset _seen_paths _path_array _new_path _dir
    else
        # Fallback to awk for bash 3.x
        PATH=$(echo "$PATH" | awk -v RS=':' '!seen[$0]++ {ORS=(NR>1?":":"")} {print}')
    fi
    export PATH
fi
