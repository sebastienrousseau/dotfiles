#!/usr/bin/env bash

# Extra Functions (Generated by Chezmoi) - loaded on demand
# Group-wise lazy loaders to reduce first-load cost.

{{ $root := . }}
{{ $groupsPath := joinPath $root.chezmoi.sourceDir ".chezmoitemplates/functions/groups.json" }}
{{ $groups := (fromJson (include $groupsPath)) }}

{{ range $group, $files := $groups }}
_dotfiles_load_group_{{ $group }}() {
  unfunction _dotfiles_load_group_{{ $group }} 2>/dev/null
  eval "$(cat <<'__DOTFILES_EOF__'
{{ range $files }}
{{ $p := joinPath $root.chezmoi.sourceDir ".chezmoitemplates/functions" . }}
{{ include $p }}

{{ end }}
__DOTFILES_EOF__
)"
}

{{ range $files }}
{{ $func := trimSuffix ".sh" . }}
{{ $func }}() { _dotfiles_load_group_{{ $group }}; {{ $func }} "$@"; }

{{ end }}
{{ end }}
