#!/usr/bin/env bash

# Extra Functions (Generated by Chezmoi) - loaded on demand
# Group-wise lazy loaders to reduce first-load cost.

{{ $root := . }}
{{ $groupsPath := joinPath $root.chezmoi.sourceDir ".chezmoitemplates/functions/groups.json" }}
{{ $groups := (fromJson (include $groupsPath)) }}

{{ range $group, $files := $groups }}
_dotfiles_load_group_{{ $group }}() {
  unfunction _dotfiles_load_group_{{ $group }} 2>/dev/null
  eval "$(cat <<'__DOTFILES_EOF__'
{{ range $files }}
{{ $p := joinPath $root.chezmoi.sourceDir ".chezmoitemplates/functions" . }}
{{ include $p }}

{{ end }}
__DOTFILES_EOF__
)"
}

{{ range $files }}
{{ $func := trimSuffix ".sh" . }}
{{ $func }}() { _dotfiles_load_group_{{ $group }}; {{ $func }} "$@"; }

{{ end }}
{{ end }}

# Pueue Background Task Wrappers (2026 Strategy)
# Use these for long-running blocking tasks.
if command -v pueue >/dev/null 2>&1; then
    # silent-run: Submit a command to pueue and forget about it.
    silent-run() {
        local cmd="$*"
        if [[ -z "$cmd" ]]; then
            echo "Usage: silent-run <command>"
            return 1
        fi
        pueue add -- "$cmd"
    }

    # notify-run: Submit a command and notify when done.
    notify-run() {
        local cmd="$*"
        if [[ -z "$cmd" ]]; then
            echo "Usage: notify-run <command>"
            return 1
        fi
        local task_id
        task_id=$(pueue add --print-id -- "$cmd")
        echo "Task $task_id submitted: $cmd"
        (pueue wait "$task_id" && echo "✅ Task $task_id finished: $cmd") &!
    }

    # bg-upgrade: Background upgrade of all package managers.
    bg-upgrade() {
        echo "🚀 Starting background upgrades (Homebrew, Nix, Chezmoi)..."
        if command -v brew >/dev/null; then silent-run "brew upgrade"; fi
        if command -v nix >/dev/null; then silent-run "nix flake update"; fi
        silent-run "chezmoi update"
        echo "Check status with 'pueue status'"
    }
fi
