# Define basic environment variables
$env.HOSTNAME = (sys host | get hostname)
$env.OS_ARCH = (sys host | get arch)
$env.OS_NAME = (sys host | get name)
$env.USER_LANGUAGE = "en_GB.UTF-8"
$env.DOTFILES_VERSION = '{{ .dotfiles_version }}'
$env.LANG = $env.USER_LANGUAGE
$env.TERM = "xterm-256color"

# Path setup: Nushell handles paths as a list in $env.PATH
let paths = [
    $"($env.HOME)/.local/bin",
    $"($env.HOME)/bin",
    "/opt/homebrew/bin",
    "/opt/homebrew/sbin",
    $"($env.HOME)/.cargo/bin",
    $"($env.HOME)/go/bin",
    $"($env.HOME)/.bun/bin",
    "/usr/local/bin",
    "/usr/bin",
    "/bin",
    "/usr/sbin",
    "/sbin"
]

$env.PATH = ($env.PATH | split row (char esep) | append $paths | uniq)

# Setup shell tool integrations
mkdir ~/.cache/nushell

# Starship prompt
if (which starship | length) > 0 {
    starship init nu | save -f ~/.cache/nushell/starship.nu
} else {
    "" | save -f ~/.cache/nushell/starship.nu
}

# Zoxide directory jumper
if (which zoxide | length) > 0 {
    zoxide init nushell | save -f ~/.cache/nushell/zoxide.nu
} else {
    "" | save -f ~/.cache/nushell/zoxide.nu
}

# Atuin shell history
if (which atuin | length) > 0 {
    atuin init nu | save -f ~/.cache/nushell/atuin.nu
} else {
    "" | save -f ~/.cache/nushell/atuin.nu
}

# Generate Nushell alias cache from bash alias library
do -i {
    bash --norc --noprofile -c '
        source "$HOME/.config/shell/90-ux-aliases.sh" 2>/dev/null
        source "$HOME/.config/shell/91-ux-aliases-lazy.sh" 2>/dev/null
        alias -p 2>/dev/null | while IFS= read -r line; do
            name="${line#alias }"
            name="${name#-- }"
            name="${name%%=*}"
            # Only valid Nushell identifiers (letters, digits, hyphens, underscores)
            [[ "$name" =~ ^[a-zA-Z_][a-zA-Z0-9_-]*$ ]] || continue
            val="${line#*=}"
            # Remove surrounding single quotes from bash alias output
            val="${val#\'}"
            val="${val%\'}"
            # Skip syntax incompatible with Nushell aliases
            case "$val" in
                *\$\{*|*\$\(*) continue ;;
                *\`*) continue ;;
                *"[["*|*"&&"*|*"||"*) continue ;;
                *";"*|*"|"*) continue ;;
                *">"*|*"<"*) continue ;;
                *"("*|*")"*) continue ;;
                "") continue ;;
            esac
            printf "alias %s = %s\n" "$name" "$val"
        done
    ' | save -f ~/.cache/nushell/bash-aliases.nu
}
# Carapace multi-shell completions
if (which carapace | length) > 0 {
    carapace _carapace nushell | save -f ~/.cache/nushell/carapace.nu
} else {
    "" | save -f ~/.cache/nushell/carapace.nu
}

# Ensure alias cache exists even if bash bridge failed
if not ($"($env.HOME)/.cache/nushell/bash-aliases.nu" | path exists) {
    "" | save -f ~/.cache/nushell/bash-aliases.nu
}
