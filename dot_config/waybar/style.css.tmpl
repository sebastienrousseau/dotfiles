{{- $t := index .themes (default "macos-monterey-dark" .theme) -}}
{{- if not $t -}}{{- $t = index .themes "macos-monterey-dark" -}}{{- end -}}
{{- /* Copyright (c) 2015-2026 Dotfiles. All rights reserved. */ -}}
{{- $bg := $t.term.bg -}}
{{- $fg := $t.term.fg -}}
{{- $accent := $t.ui.accent -}}
{{- $accent_text := $t.ui.accent_text -}}
{{- $panel := $t.ui.panel -}}
{{- $border := $t.ui.border -}}
{{- $dim := $t.term.c8 -}}
{{- $error := $t.ui.error -}}
{{- $warning := $t.ui.warning -}}
{{- $success := $t.ui.success -}}
/* ═══════════════════════════════════════════════════════════════════════════
 * Waybar Stylesheet — {{ .theme }}
 * Generated by chezmoi · dotfiles v{{ .dotfiles_version }}
 * ═══════════════════════════════════════════════════════════════════════════ */

/* --- Global --- */
* {
    font-family: "Inter", "JetBrainsMono Nerd Font", sans-serif;
    font-size: 12px;
    min-height: 0;
    border: none;
    border-radius: 0;
}

window#waybar {
    background: alpha({{ $panel }}, 0.85);
    color: {{ $fg }};
    border-bottom: 1px solid alpha({{ $border }}, 0.4);
}

/* Prevent transparent gap between modules and bar edge */
window#waybar > box {
    margin: 0;
    padding: 0 4px;
}

/* --- Module base style --- */
#workspaces,
#window,
#clock,
#cpu,
#memory,
#battery,
#network,
#pulseaudio,
#tray,
#custom-power {
    background: alpha({{ $bg }}, 0.35);
    border: 1px solid alpha({{ $border }}, 0.25);
    border-radius: 8px;
    padding: 0 10px;
    margin: 4px 2px;
    color: {{ $fg }};
    transition: all 200ms ease;
}

/* --- Workspaces --- */
#workspaces {
    padding: 0 4px;
    background: transparent;
    border: none;
}

#workspaces button {
    padding: 0 6px;
    margin: 4px 1px;
    border-radius: 8px;
    color: {{ $dim }};
    background: alpha({{ $bg }}, 0.35);
    border: 1px solid alpha({{ $border }}, 0.15);
    transition: all 200ms ease;
}

#workspaces button.active {
    color: {{ $accent_text }};
    background: {{ $accent }};
    border-color: alpha({{ $accent }}, 0.6);
    box-shadow: 0 0 4px alpha({{ $accent }}, 0.3);
}

#workspaces button:hover {
    background: alpha({{ $accent }}, 0.2);
    color: {{ $fg }};
    border-color: alpha({{ $accent }}, 0.35);
}

/* --- Window title --- */
#window {
    font-weight: 500;
    color: alpha({{ $fg }}, 0.85);
}

/* --- Clock --- */
#clock {
    font-weight: 600;
    letter-spacing: 0.5px;
    color: {{ $fg }};
}

/* --- System monitors --- */
#cpu,
#memory {
    color: alpha({{ $fg }}, 0.8);
}

#cpu:hover,
#memory:hover {
    background: alpha({{ $accent }}, 0.15);
    border-color: alpha({{ $accent }}, 0.3);
    color: {{ $fg }};
}

/* --- Battery states --- */
#battery {
    color: {{ $fg }};
}

#battery.charging,
#battery.plugged {
    color: {{ $success }};
    background: alpha({{ $success }}, 0.1);
    border-color: alpha({{ $success }}, 0.25);
}

#battery.warning:not(.charging) {
    color: {{ $warning }};
    background: alpha({{ $warning }}, 0.1);
    border-color: alpha({{ $warning }}, 0.25);
}

#battery.critical:not(.charging) {
    color: {{ $error }};
    background: alpha({{ $error }}, 0.15);
    border-color: alpha({{ $error }}, 0.3);
    animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.6; }
}

/* --- Network --- */
#network {
    color: alpha({{ $fg }}, 0.8);
}

#network.disconnected {
    color: {{ $dim }};
    background: alpha({{ $bg }}, 0.2);
}

#network.wifi {
    color: {{ $fg }};
}

/* --- Audio --- */
#pulseaudio {
    color: alpha({{ $fg }}, 0.8);
}

#pulseaudio.muted {
    color: {{ $dim }};
    background: alpha({{ $bg }}, 0.2);
}

/* --- Tray --- */
#tray {
    background: transparent;
    border: none;
    padding: 0 6px;
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

#tray > .needs-attention {
    -gtk-icon-effect: highlight;
    background: alpha({{ $warning }}, 0.15);
    border-radius: 8px;
}

/* --- Power button --- */
#custom-power {
    color: {{ $dim }};
    padding: 0 8px;
    margin-right: 4px;
}

#custom-power:hover {
    color: {{ $error }};
    background: alpha({{ $error }}, 0.15);
    border-color: alpha({{ $error }}, 0.3);
}

/* --- Tooltip --- */
tooltip {
    background: {{ $panel }};
    color: {{ $fg }};
    border: 1px solid {{ $border }};
    border-radius: 8px;
    padding: 8px 12px;
}

tooltip label {
    color: {{ $fg }};
}
