# Performance optimization - skip if not interactive
[[ -o interactive ]] || return

# Only source once if being re-sourced (in the same shell scope)
if [[ -v DOTFILES_SOURCED ]]; then
  return
fi
DOTFILES_SOURCED=1

{{- /* Input Validation: Ensure crucial variables are set */ -}}
{{- if not .chezmoi.homeDir -}}
  {{- fail "Critical Error: .chezmoi.homeDir is not set!" -}}
{{- end -}}

{{- if eq .chezmoi.os "darwin" }}
export FORCE_COLOR_OS="macOS"
{{- else if eq .chezmoi.os "linux" }}
export FORCE_COLOR_OS="Linux"
{{- else if eq .chezmoi.os "windows" }}
export FORCE_COLOR_OS="Windows"
{{- end }}

{{- $profile := default "laptop" .profile -}}
{{- $features := default (dict "zsh" true "nvim" true "tmux" true "gui" true "secrets" true) .features -}}
{{- $theme := default "catppuccin-mocha" .theme -}}
{{- $strict_mode := default false (index . "strict_mode") -}}
{{- $enabled := list -}}
{{- range $k, $v := $features }}{{- if $v }}{{- $enabled = append $enabled $k }}{{- end }}{{- end }}

export DOTFILES_PROFILE="{{ $profile }}"
export DOTFILES_FEATURES="{{ join "," $enabled }}"
export DOTFILES_THEME="{{ $theme }}"
: ${DOTFILES_STARTUP_MODE:=full}
: ${DOTFILES_FAST:=0}
: ${DOTFILES_ULTRA_FAST:=0}
: ${DOTFILES_AI:=0}
: ${DOTFILES_ALIAS_STRICT_MODE:={{ if $strict_mode }}1{{ else }}0{{ end }}}
: ${DOTFILES_ULTRA_FAST_PROMPT:=1}
: ${DOTFILES_LAYERS_LOAD:=ondemand}
: ${DOTFILES_LAYERS_PREWARM:=system,text,api}

# Default compinit based on profile (can be overridden by env)
if [[ -z "${DOTFILES_ENABLE_COMPINIT+x}" ]]; then
  case "${DOTFILES_PROFILE}" in
    laptop|desktop) DOTFILES_ENABLE_COMPINIT=1 ;;
    *) DOTFILES_ENABLE_COMPINIT=0 ;;
  esac
fi

# Startup mode override (if explicit mode set and flags not already set)
if [[ "${DOTFILES_FAST}" == "0" ]] && [[ "${DOTFILES_ULTRA_FAST}" == "0" ]]; then
  if [[ "${DOTFILES_STARTUP_MODE}" == "fast" ]]; then
    DOTFILES_FAST=1
  elif [[ "${DOTFILES_STARTUP_MODE}" == "ultra" ]]; then
    DOTFILES_ULTRA_FAST=1
    DOTFILES_FAST=1
  fi
fi

# Ultra-fast mode: minimal init (skip rc.d, plugins, prompts, AI, completions)
if [[ "${DOTFILES_ULTRA_FAST}" == "1" ]]; then
  export DOTFILES_FAST=1
  if [[ "${DOTFILES_ULTRA_FAST_PROMPT}" == "1" ]]; then
    PROMPT='%n@%m:%~%# '
    RPROMPT=''
  fi
  # Ensure no precmd/preexec hooks run in ultra-fast mode
  precmd_functions=()
  preexec_functions=()
  unset -f precmd preexec
  typeset -aU path
  return
fi

# Cached eval helper вЂ” sources cached init scripts, regenerates when stale
_SHELL_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
[[ -d "$_SHELL_CACHE" ]] || mkdir -p "$_SHELL_CACHE"

_cached_eval() {
  local label=$1; shift
  local cache="$_SHELL_CACHE/${label}.zsh"
  local bin="${commands[$1]}"
  if [[ -f "$cache" ]] && [[ -z "$bin" || "$cache" -nt "$bin" ]]; then
    source "$cache"
  else
    "$@" > "$cache" 2>/dev/null
    source "$cache"
    { zcompile "$cache" } &!
  fi
}

# Lightweight precmd hook manager (faster than add-zsh-hook)
_dotfiles_add_precmd() {
  local fn="$1"
  [[ -z "$fn" ]] && return 0
  precmd_functions=(${precmd_functions:#$fn} "$fn")
}

_dotfiles_del_precmd() {
  local fn="$1"
  [[ -z "$fn" ]] && return 0
  precmd_functions=(${precmd_functions:#$fn})
}

# Lightweight preexec hook manager
_dotfiles_add_preexec() {
  local fn="$1"
  [[ -z "$fn" ]] && return 0
  preexec_functions=(${preexec_functions:#$fn} "$fn")
}

_dotfiles_del_preexec() {
  local fn="$1"
  [[ -z "$fn" ]] && return 0
  preexec_functions=(${preexec_functions:#$fn})
}

## рџ†…рџ…°рџ†Ѓрџ…ёрџ…°рџ†Ѓрџ…ёрџ…°рџ…±рџ…»рџ…ґрџ†‚ - Core variables, plugins, and options
ZSH_RC_DIR="${HOME}/.config/zsh/rc.d"
if [[ -d "${ZSH_RC_DIR}" ]]; then
  for rc_file in "${ZSH_RC_DIR}"/**/*.zsh(N); do
    source "${rc_file}"
  done
fi

###############################
# Performance: Auto-Zcompile  #
###############################
zcompile_many() {
  local f
  for f; do
    # Compile if source is newer than .zwc or .zwc doesn't exist
    if [[ -f "$f" ]]; then
      if [[ ! -f "${f}.zwc" || "$f" -nt "${f}.zwc" ]]; then
        zcompile "$f"
      fi
    fi
  done
}

# Compile main config and generated files in background
if [[ -o interactive ]]; then
  (
    zcompile_many "${HOME}/.zshrc" \
                  "${HOME}/.config/shell/aliases.sh" \
                  "${HOME}/.config/shell/paths.sh" \
                  "${HOME}/.config/shell/functions.sh" \
                  "${HOME}/.config/shell/00-core-paths.sh" \
                  "${HOME}/.config/shell/05-core-safety.sh" \
                  "${HOME}/.config/shell/40-ls-colors.sh" \
                  "${HOME}/.config/shell/50-logic-functions-core.sh" \
                  "${HOME}/.config/shell/90-ux-aliases.sh" \
                  /opt/homebrew/opt/fzf/shell/completion.zsh \
                  /opt/homebrew/opt/fzf/shell/key-bindings.zsh &!
  )
fi

# Legacy Loader (Disabled in favor of Chezmoi Universal Config)
# _DOTFILES_CACHE="${HOME}/.zsh_dotfiles_cache"
# load_dotfiles() { ... }
# load_dotfiles

# Remove duplicates in zsh $PATH
typeset -aU path

# Load local customizations if they exist
[[ -f "${HOME}/.zshrc.local" ]] && source "${HOME}/.zshrc.local"

# Vendor / Enterprise Hooks (Site-local overrides)
# Supports drop-in configs from system management tools
if [[ -d "/etc/dotfiles/defaults.d" ]]; then
  for hook in /etc/dotfiles/defaults.d/*.sh(N); do
    source "$hook"
  done
fi

# Load Chezmoi-managed Universal Configuration Layers (Lexical Order)
# 00-19: Core (Paths, Safety)
# 20-49: Middleware (Exports, Options)
# 50-89: Toolchain & Logic (Functions, Rust tools)
# 90-99: UX (Aliases, Prompts)
#
# Optimized loading of core configurations + eager aliases
if [[ "${DOTFILES_FAST}" == "1" ]]; then
  _core_layers=(00-core-paths 05-core-safety)
else
  _core_layers=(00-core-paths 05-core-safety 90-ux-aliases)
fi
for core_layer in "${_core_layers[@]}"; do
  [[ -f "${HOME}/.config/shell/${core_layer}.sh" ]] && source "${HOME}/.config/shell/${core_layer}.sh"
done
unset _core_layers

if [[ "${DOTFILES_FAST}" != "1" ]]; then
  # On-demand loading of heavy layers (functions + aliases only when needed)
  DOTFILES_LAYERS_LOADED=0
  DOTFILES_LAYERS_LOAD_STATE=idle
  unset DOTFILES_LAYERS_LOAD_STATUS
  _dotfiles_load_heavy_layers_stage1() {
    [[ "${DOTFILES_LAYERS_LOAD_STATE}" == "stage1" || "${DOTFILES_LAYERS_LOAD_STATE}" == "ready" ]] && return 0
    DOTFILES_LAYERS_LOAD_STATE=loading
    unset DOTFILES_LAYERS_LOAD_STATUS
    [[ -f "${HOME}/.config/shell/10-secrets.sh" ]] && source "${HOME}/.config/shell/10-secrets.sh"
    [[ -f "${HOME}/.config/shell/40-ls-colors.sh" ]] && source "${HOME}/.config/shell/40-ls-colors.sh"
    [[ -f "${HOME}/.config/shell/50-logic-functions-core.sh" ]] && source "${HOME}/.config/shell/50-logic-functions-core.sh"
    [[ -f "${HOME}/.config/shell/91-ux-aliases-lazy.sh" ]] && source "${HOME}/.config/shell/91-ux-aliases-lazy.sh"
    DOTFILES_LAYERS_LOAD_STATE=stage1
  }

  _dotfiles_load_heavy_layers_stage2() {
    [[ "${DOTFILES_LAYERS_LOAD_STATE}" == "ready" ]] && return 0
    [[ -f "${HOME}/.config/shell/51-logic-functions-extra.sh" ]] && source "${HOME}/.config/shell/51-logic-functions-extra.sh"
    # Compile extra functions for faster future loads
    if command -v zcompile >/dev/null 2>&1; then
      { [[ ! -f "${HOME}/.config/shell/51-logic-functions-extra.sh.zwc" || "${HOME}/.config/shell/51-logic-functions-extra.sh" -nt "${HOME}/.config/shell/51-logic-functions-extra.sh.zwc" ]] && zcompile "${HOME}/.config/shell/51-logic-functions-extra.sh" } &!
    fi
    DOTFILES_LAYERS_LOAD_STATE=ready
    DOTFILES_LAYERS_LOAD_STATUS=ready
    export DOTFILES_LAYERS_LOAD_STATUS
  }

  _dotfiles_prewarm_groups() {
    local -a _groups
    _groups=(${(s:,:)DOTFILES_LAYERS_PREWARM})
    local g
    for g in "${_groups[@]}"; do
      [[ -z "$g" ]] && continue
      if (( ${+functions[_dotfiles_load_group_${g}]} )); then
        "_dotfiles_load_group_${g}"
      fi
    done
  }

  _dotfiles_load_heavy_layers() {
    [[ "${DOTFILES_LAYERS_LOADED}" == "1" ]] && return 0
    DOTFILES_LAYERS_LOADED=1
    _dotfiles_load_heavy_layers_stage1
    _dotfiles_load_heavy_layers_stage2
  }

  # Optional background prewarm for heavy layers (idle after first prompt)
  _dotfiles_schedule_heavy_layers() {
    if [[ "${DOTFILES_LAYERS_LOAD}" == "background" ]]; then
      if [[ -n "${ZSH_EXECUTION_STRING:-}" ]]; then
          (sleep 1; _dotfiles_load_heavy_layers_stage1; _dotfiles_load_heavy_layers_stage2; _dotfiles_prewarm_groups) &!
      else
        zmodload zsh/sched 2>/dev/null || return 0
        sched +1 _dotfiles_load_heavy_layers_stage1
        sched +2 _dotfiles_load_heavy_layers_stage2
        # Prewarm selected groups after stage2 loads stubs
        sched +3 _dotfiles_prewarm_groups
      fi
    fi
  }
  # Compatibility: use add-zsh-hook when available (tests rely on this)
  autoload -Uz add-zsh-hook
  _load_deferred_layers() {
    if (( ${+functions[add-zsh-hook]} )); then
      add-zsh-hook -d precmd _load_deferred_layers
    else
      _dotfiles_del_precmd _load_deferred_layers
    fi
    _dotfiles_schedule_heavy_layers
  }
  if (( ${+functions[add-zsh-hook]} )); then
    add-zsh-hook precmd _load_deferred_layers
  else
    _dotfiles_add_precmd _load_deferred_layers
  fi

  # Capture existing command_not_found handler (if any)
  if (( ${+functions[command_not_found_handler]} )); then
    functions[_dotfiles_prev_command_not_found_handler]="${functions[command_not_found_handler]}"
  fi

  command_not_found_handler() {
    local cmd="$1"
    shift || true

    if [[ "${DOTFILES_LAYERS_LOADED}" != "1" ]]; then
      _dotfiles_load_heavy_layers_stage1
      if (( ${+functions[$cmd]} )); then
        "$cmd" "$@"
        return $?
      fi
      if alias "$cmd" >/dev/null 2>&1; then
        local -a _args
        _args=("$@")
        eval "$cmd ${(@q)_args}"
        unset _args
        return $?
      fi
      _dotfiles_load_heavy_layers_stage2
      if (( ${+functions[$cmd]} )); then
        "$cmd" "$@"
        return $?
      fi
      if alias "$cmd" >/dev/null 2>&1; then
        local -a _args2
        _args2=("$@")
        eval "$cmd ${(@q)_args2}"
        unset _args2
        return $?
      fi
    fi

    if (( ${+functions[_dotfiles_prev_command_not_found_handler]} )); then
      _dotfiles_prev_command_not_found_handler "$cmd" "$@"
      return $?
    fi

    print -r -- "zsh: command not found: ${cmd}" >&2
    return 127
  }

  # dot load: force heavy layers now
  unalias dot 2>/dev/null
  functions[dot]='
    if [[ "$1" == "load" ]]; then
      if [[ "$2" == "--background" ]]; then
        DOTFILES_LAYERS_LOAD=background
        _dotfiles_schedule_heavy_layers
        return 0
      fi
      if [[ "$2" == "--status" ]]; then
        if [[ "$3" == "--watch" ]]; then
          local _timeout="${4:-5}"
          local _t0=$EPOCHREALTIME
          if [[ "${DOTFILES_LAYERS_LOAD_STATE:-idle}" == "idle" ]]; then
            _dotfiles_load_heavy_layers
          fi
          while [[ "${DOTFILES_LAYERS_LOAD_STATE:-idle}" != "ready" ]]; do
            sleep 0.1
            if [[ -n "${_timeout}" && "${_timeout}" != "0" ]]; then
              local _t1=$EPOCHREALTIME
              if (( (_t1 - _t0) >= _timeout )); then
                print -r -- "timeout"
                return 124
              fi
            fi
          done
        fi
        print -r -- "${DOTFILES_LAYERS_LOAD_STATE:-idle}"
        return 0
      fi
      _dotfiles_load_heavy_layers
      return 0
    fi
    "$HOME/.local/bin/dot" "$@"
  '
fi

# Essential Aliases (fallback if 90-ux-aliases.sh is unavailable)
if command -v bat >/dev/null; then
  alias cat="bat"
fi


if [[ "${DOTFILES_FAST}" != "1" ]]; then
  ## AI / Predictive Shell (opt-in)
  if [[ "${DOTFILES_AI}" == "1" ]]; then
    [[ -f "$HOME/.config/shell/custom/context_suggest.zsh" ]] && source "$HOME/.config/shell/custom/context_suggest.zsh"
    [[ -f "$HOME/.config/shell/custom/error_analysis.zsh" ]] && source "$HOME/.config/shell/custom/error_analysis.zsh"
  fi

: ${DOTFILES_DEFER_TOOLS:=1}
  _dotfiles_deferred_tools() {
    if [[ "${DOTFILES_DEFER_TOOLS}" == "1" ]]; then
      _dotfiles_del_preexec _dotfiles_deferred_tools
    else
      _dotfiles_del_precmd _dotfiles_deferred_tools
    fi

    # Mise (Universal Version Manager)
    command -v mise >/dev/null 2>&1 && _cached_eval mise-init mise activate zsh

    # Phase 33: Atuin (Memory Layer)
    command -v atuin >/dev/null 2>&1 && _cached_eval atuin-init atuin init zsh

    # Starship Prompt (High Performance)
    command -v starship >/dev/null 2>&1 && _cached_eval starship-init starship init zsh

    # Zoxide (Smart Directory Jumper) - Replaces 'cd'
    command -v zoxide >/dev/null 2>&1 && _cached_eval zoxide-init zoxide init zsh

    # FZF: init handled by ~/.config/fzf/fzf.zsh (sourced from rc.d/30-options)
    # Homebrew-only fallback for systems where fzf.zsh isn't deployed
    if command -v fzf >/dev/null 2>&1 && [[ ! -f "${HOME}/.config/fzf/fzf.zsh" ]]; then
      [[ -f "/opt/homebrew/opt/fzf/shell/completion.zsh" ]] && source "/opt/homebrew/opt/fzf/shell/completion.zsh"
      [[ -f "/opt/homebrew/opt/fzf/shell/key-bindings.zsh" ]] && source "/opt/homebrew/opt/fzf/shell/key-bindings.zsh"
    fi
  }
  if [[ "${DOTFILES_DEFER_TOOLS}" == "1" ]]; then
    _dotfiles_add_preexec _dotfiles_deferred_tools
  else
    _dotfiles_add_precmd _dotfiles_deferred_tools
  fi
fi
