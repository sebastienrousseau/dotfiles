# Topgrade configuration (managed by chezmoi)

[misc]
{{- if eq .chezmoi.os "darwin" }}
disable = ["vim", "node", "containers", "flatpak", "snap"]
{{- else }}
disable = ["vim", "node", "containers", "firmware", "helm"]
{{- end }}
pre_sudo = true
no_self_update = true
cleanup = true
display_time = true

[pre_commands]

[post_commands]

[commands]
"AI CLIs" = "ai-update"
"Mise" = "mise upgrade --yes"

[python]

[brew]

[linux]
{{- if ne .chezmoi.os "darwin" }}
yay_arguments = "-Syu --noconfirm --ignore linux-cachyos,linux-cachyos-headers,linux-cachyos-lts,linux-cachyos-lts-headers"
paru_arguments = "-Syu --noconfirm"
{{- end }}

[git]

[chezmoi]

[mise]

[npm]

[vim]

[firmware]

[flatpak]

[containers]

[rustup]

[vscode]
