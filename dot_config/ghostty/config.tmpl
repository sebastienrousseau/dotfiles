#
# Simply design to fit your shell life
# Ghostty Configuration (v{{ .dotfiles_version }})
# Cross-Platform: macOS, Linux, WSL
###############################################

{{- $theme := default "tokyonight-night" .theme -}}
{{- $fontFamily := default "JetBrains Mono" .terminal_font_family -}}
{{- $fontSize := default 12 .terminal_font_size -}}
{{- $linuxDesktop := or .features.linux_desktop .features.niri -}}
{{- $wsl := and (hasKey .chezmoi.kernel "osrelease") (contains "microsoft" (get .chezmoi.kernel "osrelease" | default "")) -}}

##########
# Theme  #
##########
# Managed by chezmoi from DOTFILES_THEME

###############
# Appearance  #
###############
background-opacity = {{ if eq .chezmoi.os "darwin" }}0.92{{ else }}0.96{{ end }}
background-blur = {{ if eq .chezmoi.os "darwin" }}14{{ else }}0{{ end }}
window-padding-x = 16
window-padding-y = 12
window-padding-balance = true
window-padding-color = background
unfocused-split-opacity = 0.95

############
# macOS UI #
############
macos-titlebar-style = tabs
macos-option-as-alt = true
window-colorspace = display-p3
window-save-state = always
window-vsync = true

################
#  Linux / WSL #
################
# Enterprise tweaks for Linux consistency
gtk-titlebar = true
# gtk-single-instance = true
# linux-cme-preedit-ime = true

################
# Typography   #
################
# Primary: User preference (Apple Native)
# Fallback logic is handled by Ghostty attempting the first found.
font-family = "{{ $fontFamily }}"
{{- if eq .chezmoi.os "darwin" }}
{{- if ne $fontFamily "SF Mono" }}
font-family = "SF Mono"
{{- end }}
{{- else }}
{{- if ne $fontFamily "JetBrainsMono Nerd Font" }}
font-family = "JetBrainsMono Nerd Font"
{{- end }}
{{- end }}
font-family = "JetBrains Mono"
font-family = "Noto Sans Mono"
font-family = "Roboto Mono"

font-size = {{ $fontSize }}
adjust-cell-width = -1
font-thicken = {{ if eq .chezmoi.os "darwin" }}false{{ else }}true{{ end }}
font-thicken-strength = {{ if eq .chezmoi.os "darwin" }}0{{ else }}1{{ end }}
adjust-cell-height = {{ if eq .chezmoi.os "darwin" }}1{{ else }}2{{ end }}
adjust-font-baseline = {{ if eq .chezmoi.os "darwin" }}-1{{ else }}0{{ end }}

#####################
# Behaviour / UX    #
#####################
scrollback-limit = 10000
working-directory = home
window-inherit-working-directory = true
{{ $shell := default "zsh" .default_shell -}}
shell-integration = {{ if eq $shell "nu" }}none{{ else }}{{ $shell }}{{ end }}
{{ if eq .chezmoi.os "darwin" -}}
command = {{ lookPath $shell }}
{{- else -}}
command = /usr/bin/env {{ $shell }}
{{- end }}
quit-after-last-window-closed = true
{{- if $linuxDesktop }}
gtk-tabs-location = top
copy-on-select = clipboard
{{- end }}
{{- if $wsl }}
window-decoration = auto
clipboard-read = allow
clipboard-write = allow
{{- end }}

################
# Keybindings  #
################
keybind = cmd+shift+,=reload_config
keybind = opt+super+left=previous_tab
keybind = opt+super+right=next_tab
# Linux/Windows friendly alternatives (using Alt/Ctrl)
keybind = ctrl+shift+,=reload_config

{{- if eq .chezmoi.os "linux" }}
####################################
# Linux Mac-style terminal keys    #
# (keyd maps physical Cmd to Ctrl) #
####################################
# copy_to_clipboard only fires when text is selected,
# otherwise Ctrl+C passes through as SIGINT
keybind = ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+t=new_tab
keybind = ctrl+w=close_surface
keybind = ctrl+n=new_window
keybind = ctrl+q=quit
keybind = ctrl+shift+left_bracket=previous_tab
keybind = ctrl+shift+right_bracket=next_tab
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size
keybind = ctrl+k=clear_screen
{{- end }}

################
# Colors       #
################
{{- $t := index .themes (default "macos-monterey-dark" .theme) -}}
{{- if not $t -}}{{- $t = index .themes "macos-monterey-dark" -}}{{- end }}
{{- $tt := $t -}}
{{- $themeName := default "macos-monterey-dark" .theme -}}
{{- if hasSuffix "-light" $themeName -}}
  {{- $darkTheme := index .themes (printf "%s-dark" (trimSuffix "-light" $themeName)) -}}
  {{- if $darkTheme -}}{{- $tt = $darkTheme -}}{{- end -}}
{{- end }}
background = {{ $tt.term.bg }}
foreground = {{ $tt.term.fg }}
cursor-color = {{ $tt.term.cursor }}
cursor-text = {{ $tt.term.cursor_text }}
selection-background = {{ $tt.term.sel_bg }}
selection-foreground = {{ $tt.term.sel_fg }}
palette = 0={{ $tt.term.c0 }}
palette = 1={{ $tt.term.c1 }}
palette = 2={{ $tt.term.c2 }}
palette = 3={{ $tt.term.c3 }}
palette = 4={{ $tt.term.c4 }}
palette = 5={{ $tt.term.c5 }}
palette = 6={{ $tt.term.c6 }}
palette = 7={{ $tt.term.c7 }}
palette = 8={{ $tt.term.c8 }}
palette = 9={{ $tt.term.c9 }}
palette = 10={{ $tt.term.c10 }}
palette = 11={{ $tt.term.c11 }}
palette = 12={{ $tt.term.c12 }}
palette = 13={{ $tt.term.c13 }}
palette = 14={{ $tt.term.c14 }}
palette = 15={{ $tt.term.c15 }}
