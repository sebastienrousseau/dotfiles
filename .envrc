export DIRENV_LOG_FORMAT=""

if [[ "${DOTFILES_USE_FLAKE:-0}" == "1" || "${CI:-0}" == "1" ]]; then
  if [[ -n "${NIX_CONFIG:-}" ]]; then
    export NIX_CONFIG="${NIX_CONFIG}
warn-dirty = false"
  else
    export NIX_CONFIG="warn-dirty = false"
  fi

  if has nix; then
    use flake
  else
    log_status "nix not found; skipping flake environment"
  fi
fi
