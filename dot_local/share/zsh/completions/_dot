#compdef dot

# Zsh completion for the dot CLI (dotfiles manager)
# Installed to: ~/.local/share/zsh/completions/_dot

_dot() {
  local -a commands

  commands=(
    # Core
    'apply:Apply dotfiles via chezmoi'
    'sync:Apply dotfiles (alias of apply)'
    'update:Pull latest changes and apply them'
    'clean-cache:Clear shell initialization caches'
    'prewarm:Regenerate shell caches for ultra-fast startup'
    'cl:Claude CLI with context patterns'
    'copilot:GitHub Copilot CLI with context patterns'
    'gemini:Gemini CLI with context patterns'
    'kiro:Kiro CLI with context patterns'
    'sgpt:Shell-GPT with context patterns'
    'ollama:Ollama with context patterns'
    'opencode:OpenCode with context patterns'
    'aider:Aider with context patterns'
    'add:Add a file to chezmoi source'
    'diff:Show chezmoi diff with exclusions'
    'status:Show configuration drift'
    'remove:Safely remove a managed file'
    'cd:Print source directory path'
    'edit:Open chezmoi source in \$EDITOR'
    'commit:AI-powered conventional commit'
    'patterns:Manage AI steering patterns'

    # Diagnostics
    'doctor:Check system health and configuration'
    'heal:Auto-repair common dotfiles issues'
    'health:Run comprehensive health check'
    'smoke-test:Run automated toolchain verification'
    'chaos:Simulate config corruption to test self-healing'
    'scorecard:Unified health/security/performance scorecard'
    'security-score:Analyze infrastructure security score'
    'intelligence:Show Dotfiles Intelligence Surface'
    'rollback:Rollback dotfiles to a previous state'
    'drift:Drift dashboard (detailed chezmoi status)'
    'history:Shell history analysis'
    'benchmark:Run shell startup benchmark'
    'perf:Show performance mode and timing'
    'load:Preload heavy shell layers'
    'load-bench:Measure time to heavy-layer readiness'
    'load-bench-pty:Measure background prewarm via PTY'
    'ai:Show AI helper status'
    'ai-setup:Interactive setup for all AI CLI tools'
    'ai-query:Context-aware RAG query over your dotfiles'
    'conflicts:Report alias/command conflicts'
    'locks:Show version locks for key tools'
    'snapshot:Capture baseline system snapshot'
    'verify:Run post-merge verification checks'

    # Tools
    'tools:Show or install nix packages'
    'new:Create a new project from a template'
    'sandbox:Launch a safe sandbox preview'
    'keys:Show keybindings catalog'
    'aliases:List/search/explain aliases and tiers'
    'learn:Start the interactive tour'
    'docs:Show repo README'
    'log-rotate:Rotate dotfiles log'
    'setup:Interactive setup (profile, features, secrets)'

    # Appearance
    'theme:Switch terminal theme'
    'wallpaper:Apply a wallpaper'
    'fonts:Install Nerd Fonts'
    'tune:Apply OS tuning'

    # Secrets
    'secrets-init:Initialize age key for secrets'
    'secrets:Manage secrets (edit|set|get|list|load|provider)'
    'secrets-create:Create an encrypted secrets file'
    'ssh-key:Encrypt an SSH key with age'
    'ssh-cert:Manage short-lived SSH certificates'
    'env:Load environment buckets from managed secrets'

    # Security
    'backup:Create a compressed backup of home'
    'bundle:Create offline archive of dotfiles environment'
    'encrypt-check:Check disk encryption status'
    'firewall:Apply firewall hardening'
    'telemetry:Disable OS telemetry'
    'dns-doh:Enable DNS-over-HTTPS'
    'lock-screen:Enforce lock screen idle settings'
    'usb-safety:Disable automount for removable media'

    # Meta
    'upgrade:Update flake, plugins, and dotfiles'
    'packages:List installed packages'
    'version:Show version information'
    '--version:Show version information'
    'help:Show help message'
  )

  _arguments -C \
    '1:command:->cmds' \
    '*::arg:->args'

  case "$state" in
    cmds)
      _describe -t commands 'dot command' commands
      ;;
    args)
      case "$words[1]" in
        new)
          if ((CURRENT == 2)); then
            local -a templates=(python go node packer molecule)
            _describe -t templates 'project template' templates
          else
            _files
          fi
          ;;
        add | remove)
          _files
          ;;
        keys)
          _message 'search pattern (optional)'
          ;;
        perf)
          local -a perf_opts=(
            '--json:Output as JSON'
            '-j:Output as JSON'
            '--profile:Include profile output'
            '-p:Include profile output'
            '--runs:Set the number of runs'
            '-r:Set the number of runs'
            '--target:Set the timing target in milliseconds'
            '-t:Set the timing target in milliseconds'
          )
          _describe -t options 'perf option' perf_opts
          ;;
        doctor)
          local -a doctor_opts=(
            '--heal:Auto-repair common issues'
            '-H:Auto-repair common issues'
            '--score:Show score output'
            '-s:Show score output'
            '--json:Emit JSON summary'
            '-j:Emit JSON summary'
            '--ai:Include AI diagnostics'
            '-A:Include AI diagnostics'
          )
          _describe -t options 'doctor option' doctor_opts
          ;;
        attest)
          local -a attest_opts=(
            '--json:Emit JSON output'
            '-j:Emit JSON output'
            '--write:Write attestation to a file'
            '-w:Write attestation to a file'
          )
          _describe -t options 'attest option' attest_opts
          ;;
        lint)
          local -a lint_opts=(
            '--check:Run check-only mode'
            '-c:Run check-only mode'
            '--fix:Apply safe fixes'
            '-f:Apply safe fixes'
          )
          _describe -t options 'lint option' lint_opts
          ;;
        mcp)
          local -a mcp_opts=(
            'registry:Show the MCP registry'
            '--strict:Treat policy warnings as errors'
            '-s:Treat policy warnings as errors'
            '--json:Emit JSON summary'
            '-j:Emit JSON summary'
          )
          _describe -t options 'mcp option' mcp_opts
          ;;
        health)
          local -a health_opts=(
            '--verbose:Show detailed checks'
            '-v:Show detailed checks'
            '--json:Emit JSON summary'
            '-j:Emit JSON summary'
            '--fix:Apply common fixes'
            '-f:Apply common fixes'
            '--force:Apply fixes without prompts'
            '-F:Apply fixes without prompts'
          )
          _describe -t options 'health option' health_opts
          ;;
        security-score)
          local -a security_opts=(
            '--verbose:Show detailed scoring'
            '-v:Show detailed scoring'
            '--quiet:Reduce output noise'
            '-q:Reduce output noise'
            '--json:Emit JSON summary'
            '-j:Emit JSON summary'
          )
          _describe -t options 'security-score option' security_opts
          ;;
        snapshot)
          local -a snapshot_opts=(
            '--baseline:Capture the baseline snapshot'
            '-b:Capture the baseline snapshot'
            '--force:Overwrite an existing snapshot'
            '-f:Overwrite an existing snapshot'
          )
          _describe -t options 'snapshot option' snapshot_opts
          ;;
        verify)
          local -a verify_opts=(
            '--security:Run security verification'
            '-s:Run security verification'
          )
          _describe -t options 'verify option' verify_opts
          ;;
        restore)
          local -a restore_opts=(
            '--list:List available backups'
            '-l:List available backups'
            '--latest:Restore the latest backup'
            '-L:Restore the latest backup'
            '--git:Restore from a git ref'
            '-g:Restore from a git ref'
            '--diff:Show a diff for a git ref'
            '-d:Show a diff for a git ref'
            '--dry-run:Preview the restore'
            '-n:Preview the restore'
          )
          _describe -t options 'restore option' restore_opts
          ;;
        load)
          local -a load_opts=('--background:Load in background' '--status:Show load status')
          _describe -t options 'load option' load_opts
          ;;
        tools)
          local -a tool_cmds=('install:Enter Nix development shell')
          _describe -t subcommands 'tools subcommand' tool_cmds
          ;;
        theme)
          local -a themes=(dark light)
          _describe -t themes 'theme mode' themes
          ;;
        ssh-cert)
          local -a cert_cmds=(
            'issue:Request a short-lived SSH certificate'
            'status:Show current certificate status'
            'revoke:Revoke an active certificate'
          )
          _describe -t subcommands 'ssh-cert subcommand' cert_cmds
          ;;
        secrets)
          local -a secrets_cmds=(
            'edit:Edit encrypted secrets'
            'set:Set a secret value'
            'get:Get a secret value'
            'list:List secret keys'
            'load:Load secrets into environment'
            'provider:Show/switch secrets provider'
          )
          _describe -t subcommands 'secrets subcommand' secrets_cmds
          ;;
        cl | copilot | gemini | kiro | sgpt | ollama | opencode | aider)
          _arguments -C \
            '(--pattern -p)'{--pattern,-p}'[Specify steering pattern]:pattern:->patterns' \
            '*:prompt: '
          if [[ "$state" == "patterns" ]]; then
            local -a patterns
            patterns=($(ls -1 "${XDG_CONFIG_HOME:-$HOME/.config}/ai/patterns" 2>/dev/null | sed 's/\.md$//'))
            _describe -t patterns 'AI pattern' patterns
          fi
          ;;
        *)
          _default
          ;;
      esac
      ;;
  esac
}

_dot "$@"
