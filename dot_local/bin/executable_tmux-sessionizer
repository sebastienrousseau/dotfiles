#!/usr/bin/env bash
# Copyright (c) 2015-2026 Dotfiles. All rights reserved.
## tmux-sessionizer — Fuzzy project session manager for tmux.
##
## Combines zoxide frecency, project directories, and active sessions
## into a single fzf picker with live previews.
##
## # Usage
##   tmux-sessionizer                     # Interactive picker
##   tmux-sessionizer /path/to/project    # Create/switch directly
##   tmux-sessionizer --kill              # Kill a session interactively
##
## # Configuration
##   TMUX_SESSIONIZER_DIRS    Search paths (colon-separated)
##   Default: ~/projects:~/work:~/src:~/.dotfiles
##
## # Keybindings (inside fzf)
##   Enter       Switch to session
##   Ctrl-X      Kill selected session
##   Ctrl-N      New session from directory
##   Ctrl-R      Refresh list

set -euo pipefail

# --- Configuration ---
SESSIONIZER_DIRS="${TMUX_SESSIONIZER_DIRS:-$HOME/projects:$HOME/work:$HOME/src:$HOME/.dotfiles}"

# --- Colors ---
readonly DIM=$'\033[2m'
readonly BOLD=$'\033[1m'
readonly GREEN=$'\033[32m'
readonly BLUE=$'\033[34m'
readonly RED=$'\033[31m'
readonly NC=$'\033[0m'

# --- Dependency checks ---
for cmd in fzf tmux; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "${RED}Error:${NC} $cmd required" >&2
    exit 1
  fi
done

# --- Helper functions ---

# Get project directories from configured paths
get_project_dirs() {
  local paths
  IFS=':' read -ra paths <<<"$SESSIONIZER_DIRS"
  for path in "${paths[@]}"; do
    local expanded="${path/#\~/$HOME}"
    [[ -d "$expanded" ]] && find "$expanded" -mindepth 1 -maxdepth 2 -type d 2>/dev/null | head -200
  done
}

# Get zoxide frecency results (most visited directories)
get_zoxide_dirs() {
  if command -v zoxide &>/dev/null; then
    zoxide query --list 2>/dev/null | head -20
  fi
}

# Get active tmux sessions with metadata
get_sessions() {
  tmux list-sessions -F "#{session_name}|#{session_windows}w|#{?session_attached,attached,}" 2>/dev/null || true
}

# Build the combined list with icons and labels
build_list() {
  local sessions projects zoxide_dirs

  # Active sessions (top priority, green icon)
  sessions=$(get_sessions)
  if [[ -n "$sessions" ]]; then
    while IFS='|' read -r name windows attached; do
      local icon="● "
      local suffix="${DIM}${windows}${NC}"
      [[ -n "$attached" ]] && suffix="${suffix} ${GREEN}${attached}${NC}"
      echo -e "${GREEN}${icon}${NC}${BOLD}${name}${NC}  ${suffix}"
    done <<<"$sessions"
  fi

  # Zoxide frecent directories (blue icon, deduplicated against sessions)
  zoxide_dirs=$(get_zoxide_dirs)
  if [[ -n "$zoxide_dirs" ]]; then
    while IFS= read -r dir; do
      [[ ! -d "$dir" ]] && continue
      local name
      name=$(basename "$dir" | tr '.' '_' | tr -cd '[:alnum:]._-')
      # Skip if already an active session
      if tmux has-session -t="$name" 2>/dev/null; then
        continue
      fi
      echo -e "${BLUE}◆ ${NC}${name}  ${DIM}${dir}${NC}"
    done <<<"$zoxide_dirs"
  fi

  # Project directories (dim icon, deduplicated)
  projects=$(get_project_dirs)
  if [[ -n "$projects" ]]; then
    while IFS= read -r dir; do
      local name
      name=$(basename "$dir" | tr '.' '_' | tr -cd '[:alnum:]._-')
      # Skip if already listed
      if tmux has-session -t="$name" 2>/dev/null; then
        continue
      fi
      # Skip if already in zoxide list
      if [[ -n "$zoxide_dirs" ]] && echo "$zoxide_dirs" | grep -qF "$dir"; then
        continue
      fi
      echo -e "${DIM}○ ${NC}${name}  ${DIM}${dir}${NC}"
    done <<<"$projects"
  fi
}

# Format session name from path
format_name() {
  [[ -n "${1:-}" ]] || return 1 # R5: validate input
  local dir="$1"
  basename "$dir" | tr '.' '_' | tr -cd '[:alnum:]._-' | head -c 32
}

# Resolve the actual path from a selection line
resolve_selection() {
  [[ -n "${1:-}" ]] || return 1 # R5: validate input
  local line="$1"
  # Strip ANSI codes
  local clean
  clean=$(echo "$line" | sed 's/\x1b\[[0-9;]*m//g')

  # Extract the name (second field after icon)
  local name path
  name=$(echo "$clean" | awk '{print $2}')
  path=$(echo "$clean" | awk '{print $3}')

  # If it's an active session, just return the name
  if tmux has-session -t="$name" 2>/dev/null; then
    echo "session:$name"
    return
  fi

  # If path exists, return it
  if [[ -n "$path" && -d "$path" ]]; then
    echo "dir:$path"
    return
  fi

  # Try to find the directory by name
  local found
  found=$(get_project_dirs 2>/dev/null | grep "/${name}$" | head -1)
  if [[ -n "$found" ]]; then
    echo "dir:$found"
    return
  fi

  # Try zoxide
  if command -v zoxide &>/dev/null; then
    found=$(zoxide query "$name" 2>/dev/null || true)
    if [[ -n "$found" && -d "$found" ]]; then
      echo "dir:$found"
      return
    fi
  fi

  echo "name:$name"
}

# Switch to or create a session
switch_to() {
  [[ -n "${1:-}" ]] || return 1 # R5: validate input
  local target="$1"
  local type="${target%%:*}"
  local value="${target#*:}"

  local session_name

  case "$type" in
    session)
      session_name="$value"
      ;;
    dir)
      session_name=$(format_name "$value")
      if ! tmux has-session -t="$session_name" 2>/dev/null; then
        tmux new-session -ds "$session_name" -c "$value"
        # Record in zoxide
        command -v zoxide &>/dev/null && zoxide add "$value" 2>/dev/null || true
      fi
      ;;
    name)
      session_name="$value"
      if ! tmux has-session -t="$session_name" 2>/dev/null; then
        tmux new-session -ds "$session_name"
      fi
      ;;
  esac

  if [[ -z "${TMUX:-}" ]]; then
    tmux attach-session -t "$session_name"
  else
    tmux switch-client -t "$session_name"
  fi
}

# Kill a session interactively
kill_session() {
  local sessions
  sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null || true)
  if [[ -z "$sessions" ]]; then
    echo "No active sessions."
    return
  fi

  local selected
  selected=$(echo "$sessions" | fzf \
    --header "Kill session" \
    --prompt "Session > " \
    --height 40% \
    --reverse \
    --no-preview \
    --no-sort) || return 0

  if [[ -n "$selected" ]]; then
    tmux kill-session -t "$selected"
    echo "${RED}Killed:${NC} $selected"
  fi
}

# --- Preview command for fzf ---
preview_cmd() {
  local line="$1"
  local clean
  clean=$(echo "$line" | sed 's/\x1b\[[0-9;]*m//g')
  local name path
  name=$(echo "$clean" | awk '{print $2}')
  path=$(echo "$clean" | awk '{print $3}')

  # If it's an active session, show pane content
  if tmux has-session -t="$name" 2>/dev/null; then
    echo "━━━ Session: $name ━━━"
    tmux list-windows -t "$name" -F "  #I: #W #{?window_active,●,○}" 2>/dev/null
    echo ""
    tmux capture-pane -pt "$name" -p 2>/dev/null | head -20
  elif [[ -n "$path" && -d "$path" ]]; then
    echo "━━━ Directory: $path ━━━"
    # Show git info if available
    if [[ -d "$path/.git" ]]; then
      echo "  Branch: $(git -C "$path" branch --show-current 2>/dev/null)"
      echo "  Commits: $(git -C "$path" rev-list --count HEAD 2>/dev/null)"
      echo ""
    fi
    ls -la "$path" 2>/dev/null | head -15
  else
    echo "No preview available"
  fi
}
export -f preview_cmd

# --- Main ---
main() {
  # Handle flags
  case "${1:-}" in
    --kill | -k)
      kill_session
      return
      ;;
    --help | -h)
      echo "${BOLD}tmux-sessionizer${NC} — fuzzy project session manager"
      echo ""
      echo "Usage: tmux-sessionizer [path | --kill | --help]"
      echo ""
      echo "Keybindings:"
      echo "  Enter     Switch to session"
      echo "  Ctrl-X    Kill selected session"
      return
      ;;
  esac

  # Direct path argument
  if [[ $# -eq 1 && -d "$1" ]]; then
    switch_to "dir:$1"
    return
  fi

  # Interactive picker
  local list
  list=$(build_list)

  if [[ -z "$list" ]]; then
    echo "${RED}No sessions or directories found.${NC}" >&2
    exit 1
  fi

  local selected
  selected=$(
    echo -e "$list" | fzf \
      --ansi \
      --header "tmux sessions  (Ctrl-X: kill)" \
      --prompt "❱ " \
      --height 60% \
      --reverse \
      --no-sort \
      --no-preview \
      --bind "ctrl-x:execute-silent(tmux kill-session -t {2} 2>/dev/null)+reload(bash -c 'source $0; build_list')"
  ) || exit 0

  if [[ -n "$selected" ]]; then
    local target
    target=$(resolve_selection "$selected")
    switch_to "$target"
  fi
}

main "$@"
