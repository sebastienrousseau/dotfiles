#!/usr/bin/env bash
# A simple implementation of AI RAG (Retrieval-Augmented Generation) for Dotfiles
# Usage: dot-ai "how do I list files?"

set -euo pipefail

QUERY="${1:-}"
if [[ -z "$QUERY" ]]; then
    echo "Usage: dot-ai 'your question'"
    exit 1
fi

DOTFILES_DIR="${HOME}/.dotfiles"

# 1. Very basic 'Retrieval' using ripgrep to find relevant context
echo "🔍 Searching dotfiles context for: $QUERY..."
# Ripgrep through aliases, functions, and READMEs, keeping context small
CONTEXT=$(rg -i --no-filename --no-line-number -C 2 -m 10 "$(echo "$QUERY" | tr ' ' '|')" "$DOTFILES_DIR/docs" "$DOTFILES_DIR/dot_config/shell" "$DOTFILES_DIR/.chezmoitemplates" 2>/dev/null || true)

if [[ -z "$CONTEXT" ]]; then
    CONTEXT="No specific context found. Just answer generically based on standard dotfile setups."
fi

# 2. 'Generation' using Ollama (or other installed CLI AI like mods/fabric)
if command -v ollama >/dev/null 2>&1; then
    echo "🧠 Generating answer using local LLM..."
    ollama run llama3.2 "You are a dotfiles expert assistant. The user's dotfiles are located at ~/.dotfiles. Answer their question concisely. Here is some context from their actual configuration:
$CONTEXT

User Question: $QUERY"
elif command -v mods >/dev/null 2>&1; then
    echo "🧠 Generating answer..."
    echo "Context: $CONTEXT

Question: $QUERY" | mods -p "Expert dotfiles assistant"
else
    echo "⚠️ AI tools (ollama/mods) not found in PATH."
    echo "Here is the local context found:"
    echo "-----------------"
    echo "$CONTEXT"
fi
