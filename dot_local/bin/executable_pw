#!/usr/bin/env bash
# Copyright (c) 2015-2026 Dotfiles. All rights reserved.
## pw — Generate a secure password and copy to clipboard.
##
## # Usage
##   pw          # 48-char password (default)
##   pw 64       # Custom length

set -euo pipefail

length="${1:-48}"

# R5: validate input is a positive integer
if [[ ! "$length" =~ ^[0-9]+$ ]] || [[ "$length" -lt 1 ]] || [[ "$length" -gt 1024 ]]; then
  echo "Usage: pw [length] (1-1024, default 48)" >&2
  exit 1
fi

if command -v pwgen &>/dev/null; then
  pwgen -sync "${length}" -1 | cb
elif command -v openssl &>/dev/null; then
  openssl rand -base64 "$((length * 3 / 4 + 1))" | head -c "$length" | cb
else
  echo "Requires pwgen or openssl" >&2
  exit 1
fi
echo "Password (${length} chars) copied to clipboard."
