#!/usr/bin/env bash
# Copyright (c) 2015-2026 Dotfiles. All rights reserved.
set -euo pipefail

# Dotfiles CLI Entry Point - v0.2.495

# Ensure XDG Base Directory variables are set
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Ensure PIPX paths are set
export PIPX_HOME="${XDG_DATA_HOME}/pipx"
export PIPX_BIN_DIR="${HOME}/.local/bin"

# Ensure Nix is in PATH if installed
if [ -e "${HOME}/.nix-profile/etc/profile.d/nix.sh" ]; then
  . "${HOME}/.nix-profile/etc/profile.d/nix.sh"
fi

VERSION="0.2.495"

COMMAND="${1:-}"
if [ -n "${1:-}" ]; then
  shift
fi

UI_COLOR=0
UI_BOLD=""
UI_RESET=""
UI_BLUE=""
UI_CYAN=""
UI_GREEN=""
UI_YELLOW=""
UI_RED=""
UI_GRAY=""

ui_init() {
  if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    UI_COLOR=1
    UI_BOLD=$'\033[1m'
    UI_RESET=$'\033[0m'
    UI_BLUE=$'\033[38;5;63m'
    UI_CYAN=$'\033[38;5;81m'
    UI_GREEN=$'\033[38;5;42m'
    UI_YELLOW=$'\033[38;5;214m'
    UI_RED=$'\033[38;5;196m'
    UI_GRAY=$'\033[38;5;244m'
  fi
}

ui_header() {
  local text="$1"
  ui_init
  if [[ "$UI_COLOR" == "1" ]]; then
    printf "\n  %s%s%s\n\n" "${UI_BOLD}${UI_BLUE}" "$text" "$UI_RESET"
  else
    printf "\n%s\n\n" "$text"
  fi
}

ui_section() {
  local text="$1"
  if [[ "$UI_COLOR" == "1" ]]; then
    printf "  %s%s%s\n" "${UI_BOLD}${UI_CYAN}" "$text" "$UI_RESET"
  else
    printf "  %s\n" "$text"
  fi
}

ui_cmd() {
  local cmd="$1"
  local desc="$2"
  if [[ "$UI_COLOR" == "1" ]]; then
    printf "  %b%-16s%b %s\n" "${UI_GREEN}" "$cmd" "${UI_RESET}" "$desc"
  else
    printf "  %-16s %s\n" "$cmd" "$desc"
  fi
}

ui_info() {
  local label="$1"
  local msg="$2"
  if [[ "$UI_COLOR" == "1" ]]; then
    printf "  %b•%b %-14s %s\n" "${UI_GRAY}" "${UI_RESET}" "$label" "$msg"
  else
    printf "  * %-14s %s\n" "$label" "$msg"
  fi
}

ui_warn() {
  local msg="$1"
  if [[ "$UI_COLOR" == "1" ]]; then
    printf "  %b⚠%b %s\n" "${UI_YELLOW}" "${UI_RESET}" "$msg"
  else
    printf "  [WARN] %s\n" "$msg"
  fi
}

ui_fail() {
  local msg="$1"
  if [[ "$UI_COLOR" == "1" ]]; then
    printf "  %b✗%b %s\n" "${UI_RED}" "${UI_RESET}" "$msg" >&2
  else
    printf "  [FAIL] %s\n" "$msg" >&2
  fi
}

show_help() {
  ui_header "Dotfiles CLI"
  ui_info "Usage" "dot [command]"
  ui_info "Version" "v$VERSION"
  echo ""

  ui_section "Core Commands"
  ui_cmd "apply" "Apply dotfiles (chezmoi apply)"
  ui_cmd "sync" "Apply dotfiles (alias of apply)"
  ui_cmd "update" "Pull latest changes and apply (chezmoi update)"
  ui_cmd "clean-cache" "Clear shell initialization caches"
  ui_cmd "prewarm" "Regenerate shell caches for ultra-fast startup"
  ui_cmd "add" "Add a file to chezmoi source"
  ui_cmd "diff" "Show chezmoi diff with exclusions"
  ui_cmd "status" "Show configuration drift (chezmoi status)"
  ui_cmd "remove" "Safely remove a managed file"
  ui_cmd "cd" "Print source directory path (use: cd \$(dot cd))"
  ui_cmd "edit" "Open chezmoi source in \$EDITOR"
  ui_cmd "patterns" "Manage AI steering patterns"
  ui_cmd "commit" "AI-powered conventional commit"
  echo ""

  ui_section "Diagnostics"
  ui_cmd "doctor" "Check system health and configuration"
  ui_cmd "heal" "Auto-repair common dotfiles issues"
  ui_cmd "health" "Run comprehensive health check"
  ui_cmd "verify" "Run security and integrity verification"
  ui_cmd "scorecard" "System health and security scorecard"
  ui_cmd "intelligence" "Show Dotfiles Intelligence Surface"
  ui_cmd "snapshot" "Capture baseline system snapshot"
  ui_cmd "smoke-test" "Run automated toolchain verification"
  ui_cmd "chaos" "Simulate config corruption to test self-healing"
  ui_cmd "bundle" "Create offline archive of dotfiles environment"
  ui_cmd "rollback" "Rollback dotfiles to a previous state"
  ui_cmd "drift" "Drift dashboard (detailed chezmoi status)"
  ui_cmd "history" "Shell history analysis"
  ui_cmd "benchmark" "Run shell startup benchmark"
  ui_cmd "perf" "Show performance mode and quick timing"
  ui_cmd "load" "Preload heavy shell layers"
  ui_cmd "load-bench" "Measure time to heavy-layer readiness"
  ui_cmd "load-bench-pty" "Measure background prewarm readiness via PTY"
  ui_cmd "ai" "Show AI helper status (opt-in)"
  ui_cmd "ai-setup" "Interactive setup for all AI CLI tools"
  ui_cmd "ai-query" "Context-aware RAG query over your dotfiles"
  echo ""

  ui_section "Tools"
  ui_cmd "cl" "Claude CLI with context patterns"
  ui_cmd "gemini" "Gemini CLI with context patterns"
  ui_cmd "kiro" "Kiro CLI with context patterns"
  ui_cmd "sgpt" "Shell-GPT with context patterns"
  ui_cmd "ollama" "Ollama with context patterns"
  ui_cmd "opencode" "OpenCode with context patterns"
  ui_cmd "aider" "Aider with context patterns"
  ui_cmd "tools" "Show or install nix packages"
  ui_cmd "new" "Create a new project from a template"
  ui_cmd "sandbox" "Launch a safe sandbox preview (Docker/Podman)"
  ui_cmd "keys" "Show keybindings catalog"
  ui_cmd "learn" "Start the interactive tour of your new tools"
  ui_cmd "docs" "Show repo README"
  ui_cmd "log-rotate" "Rotate ~/.local/share/dotfiles.log"
  echo ""

  ui_section "Appearance"
  ui_cmd "theme" "Switch terminal theme (dark/light)"
  ui_cmd "wallpaper" "Apply a wallpaper from your library"
  ui_cmd "fonts" "Install Nerd Fonts (JetBrainsMono by default)"
  ui_cmd "tune" "Apply OS tuning (opt-in)"
  echo ""

  ui_section "Secrets"
  ui_cmd "secrets-init" "Initialize age key for secrets"
  ui_cmd "secrets" "Edit encrypted secrets (age)"
  ui_cmd "secrets-create" "Create an encrypted secrets file"
  ui_cmd "ssh-key" "Encrypt an SSH key locally with age"
  ui_cmd "ssh-cert" "Manage short-lived SSH certificates"
  echo ""

  ui_section "Security (opt-in)"
  ui_cmd "backup" "Create a compressed backup of your home"
  ui_cmd "encrypt-check" "Check disk encryption status"
  ui_cmd "firewall" "Apply firewall hardening"
  ui_cmd "telemetry" "Disable OS telemetry"
  ui_cmd "dns-doh" "Enable DNS-over-HTTPS"
  ui_cmd "lock-screen" "Enforce lock screen idle settings"
  ui_cmd "usb-safety" "Disable automount for removable media"
  echo ""

  ui_section "Meta"
  ui_cmd "upgrade" "Update flake, plugins, and dotfiles"
  ui_cmd "packages" "List installed packages and package managers"
  ui_cmd "--version" "Show version information"
  ui_cmd "help" "Show this help message"
}

resolve_source_dir() {
  local dir=""
  if [ -n "${CHEZMOI_SOURCE_DIR:-}" ] && [ -d "$CHEZMOI_SOURCE_DIR" ]; then
    dir="$CHEZMOI_SOURCE_DIR"
  elif [ -d "$HOME/.dotfiles" ]; then
    dir="$HOME/.dotfiles"
  elif [ -d "$HOME/.local/share/chezmoi" ]; then
    dir="$HOME/.local/share/chezmoi"
  elif [ -f "package.json" ] && grep -q '"name": "dotfiles"' package.json 2>/dev/null; then
    dir="$(pwd)"
  fi
  echo "$dir"
}

run_script() {
  local script_rel_path="${1#/}" # Remove leading slash if present
  local description="$2"
  shift 2
  local src_dir="$(resolve_source_dir)"

  local background=0
  if [[ "${1:-}" == "--background" || "${1:-}" == "-b" ]]; then
    background=1
    shift
  fi

  if [ -n "$src_dir" ] && [ -f "$src_dir/$script_rel_path" ]; then

    if [[ $background -eq 1 ]] && command -v pueue >/dev/null && pueue status >/dev/null 2>&1; then
      ui_info "Background" "Offloading $description to Pueue queue"
      pueue add -- bash "$src_dir/$script_rel_path" "$@"
    else
      if [[ $background -eq 1 ]]; then
        ui_warn "Pueue not available, running $description in foreground"
      fi
      exec bash "$src_dir/$script_rel_path" "$@"
    fi
  else
    ui_fail "$description not found at $src_dir/$script_rel_path"
    exit 1
  fi
}

case "$COMMAND" in
  apply | sync)
    chezmoi apply --force
    ;;
  update)
    run_script "scripts/ops/chezmoi-update.sh" "Update script" "$@"
    # Regenerate caches after update (if not running in background)
    if [[ "$1" != "--background" && "$1" != "-b" ]]; then
      "$0" prewarm
    fi
    ;;
  clean-cache)
    ui_info "Cache" "Clearing shell initialization caches"
    CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
    rm -rf "$CACHE_DIR/zsh"/*-init.zsh "$CACHE_DIR/zsh"/*.zwc 2>/dev/null || true
    rm -rf "$CACHE_DIR/bash"/*-init.bash 2>/dev/null || true
    rm -rf "$CACHE_DIR/fish"/*-init.fish 2>/dev/null || true
    rm -rf "$CACHE_DIR/nushell"/*.nu 2>/dev/null || true
    ui_info "Cache" "Cleared. Restart shell to regenerate"
    ;;
  prewarm)
    "$0" clean-cache
    SRC_DIR="$(resolve_source_dir)"
    if [ -n "$SRC_DIR" ] && [ -f "$SRC_DIR/scripts/ops/prewarm.sh" ]; then
      bash "$SRC_DIR/scripts/ops/prewarm.sh"
    fi
    ;;
  add)
    if [[ $# -eq 0 ]]; then
      echo "Error: 'add' command requires at least 1 argument."
      echo "Usage: dot add <file>..."
      exit 1
    fi
    chezmoi add "$@"
    ;;
  diff)
    SRC_DIR="$(resolve_source_dir)"
    if [ -n "$SRC_DIR" ] && [ -f "$SRC_DIR/scripts/ops/chezmoi-diff.sh" ]; then
      exec bash "$SRC_DIR/scripts/ops/chezmoi-diff.sh" "$@"
    else
      chezmoi diff "$@"
    fi
    ;;
  status)
    chezmoi status "$@"
    ;;
  commit)
    run_script "dot_local/bin/executable_git-ai-commit" "Git AI commit script" "$@"
    ;;
  patterns)
    run_script "scripts/dot/commands/patterns.sh" "AI patterns script" "$@"
    ;;
  remove)
    chezmoi forget "$@"
    ;;
  cd)
    resolve_source_dir
    ;;
  edit)
    exec chezmoi cd
    ;;
  doctor)
    run_script "scripts/diagnostics/doctor.sh" "Doctor script" "$@"
    ;;
  scorecard)
    run_script "scripts/diagnostics/scorecard.sh" "Scorecard script" "$@"
    ;;
  snapshot)
    run_script "scripts/diagnostics/snapshot.sh" "Snapshot script" "$@"
    ;;
  history)
    run_script "scripts/diagnostics/history.sh" "History script" "$@"
    ;;
  setup)
    run_script "scripts/ops/setup.sh" "Setup script" "$@"
    ;;
  theme)
    run_script "scripts/ops/theme.sh" "Theme script" "$@"
    ;;
  wallpaper)
    run_script "scripts/ops/wallpaper.sh" "Wallpaper script" "$@"
    ;;
  fonts)
    run_script "scripts/ops/fonts.sh" "Fonts script" "$@"
    ;;
  secrets-init)
    run_script "scripts/security/secrets-init.sh" "Secrets init script" "$@"
    ;;
  secrets)
    run_script "scripts/security/manage-secrets.sh" "Secrets management script" "$@"
    ;;
  secrets-create)
    run_script "scripts/security/secrets-create.sh" "Secrets creation script" "$@"
    ;;
  ssh-key)
    run_script "scripts/security/ssh-key.sh" "SSH key script" "$@"
    ;;
  ssh-cert)
    run_script "scripts/security/ssh-cert.sh" "SSH cert script" "$@"
    ;;
  backup)
    run_script "scripts/security/backup.sh" "Backup script" "$@"
    ;;
  encrypt-check)
    run_script "scripts/security/encryption-check.sh" "Encryption check script" "$@"
    ;;
  firewall)
    run_script "scripts/security/firewall.sh" "Firewall script" "$@"
    ;;
  telemetry)
    run_script "scripts/security/telemetry.sh" "Telemetry script" "$@"
    ;;
  dns-doh)
    run_script "scripts/security/dns-doh.sh" "DNS-over-HTTPS script" "$@"
    ;;
  lock-screen)
    run_script "scripts/security/lock-screen.sh" "Lock screen script" "$@"
    ;;
  usb-safety)
    run_script "scripts/security/usb-safety.sh" "USB safety script" "$@"
    ;;
  upgrade)
    run_script "scripts/ops/upgrade.sh" "Upgrade script" "$@"
    ;;
  packages)
    run_script "scripts/diagnostics/packages.sh" "Packages script" "$@"
    ;;
  learn)
    run_script "scripts/ops/tour.sh" "Tour script" "$@"
    ;;
  keys)
    run_script "scripts/diagnostics/keys.sh" "Keys script" "$@"
    ;;
  docs)
    SRC_DIR="$(resolve_source_dir)"
    if [ -f "$SRC_DIR/README.md" ]; then
      if command -v glow >/dev/null 2>&1; then
        glow "$SRC_DIR/README.md"
      else
        cat "$SRC_DIR/README.md"
      fi
    else
      ui_fail "README not found"
      exit 1
    fi
    ;;
  log-rotate)
    ui_info "Log" "Rotating ~/.local/share/dotfiles.log"
    mv "$HOME/.local/share/dotfiles.log" "$HOME/.local/share/dotfiles.log.old" 2>/dev/null || true
    touch "$HOME/.local/share/dotfiles.log"
    ui_info "Log" "Rotation complete"
    ;;
  sandbox)
    SRC_DIR="$(resolve_source_dir)"
    if [ -z "$SRC_DIR" ]; then
      ui_fail "Dotfiles source not found"
      exit 1
    fi
    if command -v docker >/dev/null; then
      ui_info "Sandbox" "Launching via Docker"
      docker build -f "$SRC_DIR/tests/Dockerfile.sandbox" -t dotfiles-sandbox "$SRC_DIR"
      exec docker run --rm -it dotfiles-sandbox
    elif command -v podman >/dev/null; then
      ui_info "Sandbox" "Launching via Podman"
      podman build -f "$SRC_DIR/tests/Dockerfile.sandbox" -t dotfiles-sandbox "$SRC_DIR"
      exec podman run --rm -it dotfiles-sandbox
    else
      ui_fail "Docker or Podman is required for sandbox"
      exit 1
    fi
    ;;
  heal) run_script "scripts/ops/heal.sh" "Heal script" "$@" ;;
  health | health-check) run_script "scripts/ops/health-check.sh" "Health check script" "$@" ;;
  smoke-test) run_script "scripts/diagnostics/smoke-test.sh" "Smoke test script" "$@" ;;
  verify) run_script "scripts/diagnostics/verify.sh" "Verification script" "$@" ;;
  security-score) run_script "scripts/diagnostics/security-score.sh" "Security score script" "$@" ;;
  intelligence) run_script "scripts/dot/lib/bento.sh" "Intelligence Surface" "$@" ;;
  cl | claude | gemini | kiro | sgpt | ollama | opencode | aider) run_script "scripts/dot/commands/ai.sh" "AI Bridge" "$COMMAND" "$@" ;;
  drift) run_script "scripts/diagnostics/drift-dashboard.sh" "Drift script" "$@" ;;
  chaos) run_script "scripts/ops/chaos.sh" "Chaos engineering script" "$@" ;;
  bundle) run_script "scripts/ops/bundle.sh" "Offline bundle script" "$@" ;;
  rollback) run_script "scripts/ops/rollback.sh" "Rollback script" "$@" ;;
  benchmark) run_script "tests/benchmark.sh" "Benchmark script" "$@" ;;
  # load) -- removed: scripts/ops/load.sh does not exist
  tools) run_script "scripts/dot/commands/tools.sh" "Tools script" "tools" "$@" ;;
  new) run_script "scripts/dot/commands/tools.sh" "Tools script" "new" "$@" ;;
  perf)
    PERF_JSON=0
    PERF_PRECMD=0
    for arg in "$@"; do
      case "$arg" in
        --json) PERF_JSON=1 ;;
        --precmd) PERF_PRECMD=1 ;;
      esac
    done
    if [ "$PERF_JSON" = "0" ]; then
      ui_header "Dotfiles Performance"
      ui_info "DOTFILES_FAST" "${DOTFILES_FAST:-0}"
      ui_info "DOTFILES_ULTRA_FAST" "${DOTFILES_ULTRA_FAST:-0}"
      ui_info "DOTFILES_DEFER_ZINIT" "${DOTFILES_DEFER_ZINIT:-1}"
      ui_info "DOTFILES_ENABLE_COLORS" "${DOTFILES_ENABLE_COLORS:-0}"
      ui_info "DOTFILES_AI" "${DOTFILES_AI:-0}"
      ui_info "PRECMD_HOOKS" "${PERF_PRECMD}"
    fi
    if command -v python3 >/dev/null 2>&1; then
      PERF_JSON="$PERF_JSON" PERF_PRECMD="$PERF_PRECMD" python3 - <<'PY'
import json
import os
import time

def get_status():
    status = {
        "fast": os.environ.get("DOTFILES_FAST", "0") == "1",
        "ultra_fast": os.environ.get("DOTFILES_ULTRA_FAST", "0") == "1",
        "defer_zinit": os.environ.get("DOTFILES_DEFER_ZINIT", "1") == "1",
        "ai": os.environ.get("DOTFILES_AI", "0") == "1"
    }
    return status

if os.environ.get("PERF_JSON", "0") == "1":
    print(json.dumps(get_status()))
PY
    else
      ui_warn "python3 not found; run: zsh -i -c exit"
    fi
    ;;
  load-bench)
    command dot-load-benchmark "$@"
    ;;
  load-bench-pty)
    command dot-load-benchmark-pty "$@"
    ;;
  ai)
    ui_header "AI Helpers"
    ui_info "DOTFILES_AI" "${DOTFILES_AI:-0}"
    ui_info "Enable" "export DOTFILES_AI=1"
    if command -v ollama >/dev/null 2>&1; then
      ui_cmd "ollama" "installed"
    else
      ui_cmd "ollama" "not installed"
    fi
    if command -v llm >/dev/null 2>&1; then
      ui_cmd "llm" "installed"
    else
      ui_cmd "llm" "not installed"
    fi
    ;;
  ai-setup) run_script "scripts/ops/ai-setup.sh" "AI setup script" "$@" ;;
  ai-query) run_script "dot_local/bin/executable_dot-ai" "AI RAG script" "$@" ;;
  tune)
    SRC_DIR="$(resolve_source_dir)"
    if [ -z "$SRC_DIR" ]; then
      ui_fail "Dotfiles source not found"
      exit 1
    fi
    if [ -f "$SRC_DIR/scripts/ops/setup.sh" ]; then
      exec bash "$SRC_DIR/scripts/ops/setup.sh" --tune
    else
      ui_fail "Tuning script not found"
      exit 1
    fi
    ;;
  help | --help | -h)
    show_help
    ;;
  --version | -v)
    ui_info "Version" ".dotfiles $VERSION"
    ;;
  *)
    if [ -z "$COMMAND" ]; then
      show_help
    else
      ui_fail "Unknown command: $COMMAND"
      ui_info "Hint" "Try 'dot help' for usage"
      exit 1
    fi
    ;;
esac
