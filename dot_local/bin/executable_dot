#!/usr/bin/env bash
# Copyright (c) 2015-2026 . All rights reserved.
set -e

# Dotfiles CLI Entry Point - v0.2.494

# Ensure XDG Base Directory variables are set
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Ensure PIPX paths are set
export PIPX_HOME="${XDG_DATA_HOME}/pipx"
export PIPX_BIN_DIR="${HOME}/.local/bin"

# Ensure Nix is in PATH if installed
if [ -e "${HOME}/.nix-profile/etc/profile.d/nix.sh" ]; then
  . "${HOME}/.nix-profile/etc/profile.d/nix.sh"
fi

VERSION="0.2.494"

COMMAND="$1"
if [ -n "$1" ]; then
  shift
fi

show_help() {
  echo "Usage: dot [command]"
  echo ""
  echo "Core Commands:"
  echo "  apply       Apply dotfiles (chezmoi apply)"
  echo "  sync        Apply dotfiles (alias of apply)"
  echo "  update      Pull latest changes and apply them (chezmoi update)"
  echo "  clean-cache Clear shell initialization caches"
  echo "  prewarm     Regenerate shell caches for ultra-fast startup"
  echo "  add         Add a file to chezmoi source"
  echo "  diff        Show chezmoi diff with exclusions"
  echo "  status      Show configuration drift (chezmoi status)"
  echo "  remove      Safely remove a managed file"
  echo "  cd          Print source directory path (use: cd \$(dot cd))"
  echo "  edit        Open chezmoi source in \$EDITOR"
  echo "  patterns    Manage AI steering patterns"
  echo "  commit      AI-powered conventional commit"
  echo ""

  echo "Diagnostics:"
  echo "  doctor      Check system health and configuration"
  echo "  heal        Auto-repair common dotfiles issues"
  echo "  health      Run comprehensive health check"
  echo "  verify      Run security and integrity verification"
  echo "  scorecard   System health and security scorecard
  intelligence Show Dotfiles Intelligence Surface
  intelligence Show Dotfiles Intelligence Surface"
  echo "  snapshot    Capture baseline system snapshot"
  echo "  smoke-test  Run automated toolchain verification"
  echo "  chaos       Simulate config corruption to test self-healing"
  echo "  bundle      Create offline archive of dotfiles environment"
  echo "  rollback    Rollback dotfiles to a previous state"
  echo "  drift       Drift dashboard (detailed chezmoi status)"
  echo "  history     Shell history analysis"
  echo "  benchmark   Run shell startup benchmark"
  echo "  perf        Show current performance mode and quick timing (--json, --precmd)"
  echo "  load        Preload heavy shell layers (dot load [--background|--status [--watch]])"
  echo "  load-bench  Measure time to heavy-layer readiness"
  echo "  load-bench-pty  Measure background prewarm readiness via PTY"
  echo "  ai          Show AI helper status (opt-in)"
  echo "  ai-setup    Interactive setup for all AI CLI tools"
  echo "  ai-query    Context-aware RAG query over your dotfiles"
  echo ""

  echo "Tools:"
  echo "  cl          Claude CLI with context patterns"
  echo "  gemini      Gemini CLI with context patterns"
  echo "  kiro        Kiro CLI with context patterns"
  echo "  sgpt        Shell-GPT with context patterns"
  echo "  ollama      Ollama with context patterns"
  echo "  opencode    OpenCode with context patterns"
  echo "  aider       Aider with context patterns"

  echo "  tools       Show or install nix packages (dot tools [install])"
  echo "  new         Create a new project from a template"
  echo "  sandbox     Launch a safe sandbox preview (Docker/Podman)"
  echo "  keys        Show keybindings catalog"
  echo "  learn       Start the interactive tour of your new tools"
  echo "  docs        Show repo README"
  echo "  log-rotate  Rotate ~/.local/share/dotfiles.log"
  echo ""
  echo "Appearance:"
  echo "  theme       Switch terminal theme (dark/light)"
  echo "  wallpaper   Apply a wallpaper from your library"
  echo "  fonts       Install Nerd Fonts (JetBrainsMono by default)"
  echo "  tune        Apply OS tuning (opt-in)"
  echo ""
  echo "Secrets:"
  echo "  secrets-init    Initialize age key for secrets"
  echo "  secrets         Edit encrypted secrets (age)"
  echo "  secrets-create  Create an encrypted secrets file"
  echo "  ssh-key         Encrypt an SSH key locally with age"
  echo "  ssh-cert        Manage short-lived SSH certificates (issue/status/revoke)"
  echo ""
  echo "Security (opt-in):"
  echo "  backup        Create a compressed backup of your home"
  echo "  encrypt-check Check disk encryption status"
  echo "  firewall      Apply firewall hardening"
  echo "  telemetry     Disable OS telemetry"
  echo "  dns-doh       Enable DNS-over-HTTPS"
  echo "  lock-screen   Enforce lock screen idle settings"
  echo "  usb-safety    Disable automount for removable media"
  echo ""
  echo "Meta:"
  echo "  upgrade     Update flake, plugins, and dotfiles"
  echo "  packages    List installed packages and package managers"
  echo "  --version   Show version information"
  echo "  help        Show this help message"
}

resolve_source_dir() {
  local dir=""
  if [ -n "${CHEZMOI_SOURCE_DIR:-}" ] && [ -d "$CHEZMOI_SOURCE_DIR" ]; then
    dir="$CHEZMOI_SOURCE_DIR"
  elif [ -d "$HOME/.dotfiles" ]; then
    dir="$HOME/.dotfiles"
  elif [ -d "$HOME/.local/share/chezmoi" ]; then
    dir="$HOME/.local/share/chezmoi"
  elif [ -f "package.json" ] && grep -q '"name": "dotfiles"' package.json 2>/dev/null; then
    dir="$(pwd)"
  fi
  echo "$dir"
}

run_script() {
  local script_rel_path="${1#/}" # Remove leading slash if present
  local description="$2"
  shift 2
  local src_dir="$(resolve_source_dir)"

  local background=0
  if [[ "${1:-}" == "--background" || "${1:-}" == "-b" ]]; then
    background=1
    shift
  fi

  if [ -n "$src_dir" ] && [ -f "$src_dir/$script_rel_path" ]; then

    if [[ $background -eq 1 ]] && command -v pueue >/dev/null && pueue status >/dev/null 2>&1; then
      echo "Offloading $description to Pueue background queue..."
      pueue add -- bash "$src_dir/$script_rel_path" "$@"
    else
      if [[ $background -eq 1 ]]; then
        echo "Pueue not available, running $description in foreground..."
      fi
      exec bash "$src_dir/$script_rel_path" "$@"
    fi
  else
    echo "$description not found at $src_dir/$script_rel_path"
    exit 1
  fi
}

case "$COMMAND" in
  apply | sync)
    chezmoi apply --force
    ;;
  update)
    run_script "scripts/ops/chezmoi-update.sh" "Update script" "$@"
    # Regenerate caches after update (if not running in background)
    if [[ "$1" != "--background" && "$1" != "-b" ]]; then
      "$0" prewarm
    fi
    ;;
  clean-cache)
    echo "Clearing shell initialization caches..."
    CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
    rm -rf "$CACHE_DIR/zsh"/*-init.zsh "$CACHE_DIR/zsh"/*.zwc 2>/dev/null || true
    rm -rf "$CACHE_DIR/bash"/*-init.bash 2>/dev/null || true
    rm -rf "$CACHE_DIR/fish"/*-init.fish 2>/dev/null || true
    rm -rf "$CACHE_DIR/nushell"/*.nu 2>/dev/null || true
    echo "Caches cleared. Restart your shell to regenerate."
    ;;
  prewarm)
    "$0" clean-cache
    SRC_DIR="$(resolve_source_dir)"
    if [ -n "$SRC_DIR" ] && [ -f "$SRC_DIR/scripts/ops/prewarm.sh" ]; then
      bash "$SRC_DIR/scripts/ops/prewarm.sh"
    fi
    ;;
  add)
    if [[ $# -eq 0 ]]; then
      echo "Error: 'add' command requires at least 1 argument."
      echo "Usage: dot add <file>..."
      exit 1
    fi
    chezmoi add "$@"
    ;;
  diff)
    SRC_DIR="$(resolve_source_dir)"
    if [ -n "$SRC_DIR" ] && [ -f "$SRC_DIR/scripts/ops/chezmoi-diff.sh" ]; then
      exec bash "$SRC_DIR/scripts/ops/chezmoi-diff.sh" "$@"
    else
      chezmoi diff "$@"
    fi
    ;;
  status)
    chezmoi status "$@"
    ;;
  commit)
    run_script "dot_local/bin/executable_git-ai-commit" "Git AI commit script" "$@"
    ;;
  patterns)
    run_script "scripts/dot/commands/patterns.sh" "AI patterns script" "$@"
    ;;
  remove)
    chezmoi forget "$@"
    ;;
  cd)
    resolve_source_dir
    ;;
  edit)
    exec chezmoi cd
    ;;
  doctor)
    run_script "scripts/diagnostics/doctor.sh" "Doctor script" "$@"
    ;;
  scorecard)
    run_script "scripts/diagnostics/scorecard.sh" "Scorecard script" "$@"
    ;;
  snapshot)
    run_script "scripts/diagnostics/snapshot.sh" "Snapshot script" "$@"
    ;;
  history)
    run_script "scripts/diagnostics/history.sh" "History script" "$@"
    ;;
  setup)
    run_script "scripts/ops/setup.sh" "Setup script" "$@"
    ;;
  theme)
    run_script "scripts/ops/theme.sh" "Theme script" "$@"
    ;;
  wallpaper)
    run_script "scripts/ops/wallpaper.sh" "Wallpaper script" "$@"
    ;;
  fonts)
    run_script "scripts/ops/fonts.sh" "Fonts script" "$@"
    ;;
  secrets-init)
    run_script "scripts/security/secrets-init.sh" "Secrets init script" "$@"
    ;;
  secrets)
    run_script "scripts/security/manage-secrets.sh" "Secrets management script" "$@"
    ;;
  secrets-create)
    run_script "scripts/security/secrets-create.sh" "Secrets creation script" "$@"
    ;;
  ssh-key)
    run_script "scripts/security/ssh-key.sh" "SSH key script" "$@"
    ;;
  ssh-cert)
    run_script "scripts/security/ssh-cert.sh" "SSH cert script" "$@"
    ;;
  backup)
    run_script "scripts/security/backup.sh" "Backup script" "$@"
    ;;
  encrypt-check)
    run_script "scripts/security/encryption-check.sh" "Encryption check script" "$@"
    ;;
  firewall)
    run_script "scripts/security/firewall.sh" "Firewall script" "$@"
    ;;
  telemetry)
    run_script "scripts/security/telemetry.sh" "Telemetry script" "$@"
    ;;
  dns-doh)
    run_script "scripts/security/dns-doh.sh" "DNS-over-HTTPS script" "$@"
    ;;
  lock-screen)
    run_script "scripts/security/lock-screen.sh" "Lock screen script" "$@"
    ;;
  usb-safety)
    run_script "scripts/security/usb-safety.sh" "USB safety script" "$@"
    ;;
  upgrade)
    run_script "scripts/ops/upgrade.sh" "Upgrade script" "$@"
    ;;
  packages)
    run_script "scripts/diagnostics/packages.sh" "Packages script" "$@"
    ;;
  learn)
    run_script "scripts/ops/tour.sh" "Tour script" "$@"
    ;;
  keys)
    run_script "scripts/diagnostics/keys.sh" "Keys script" "$@"
    ;;
  docs)
    SRC_DIR="$(resolve_source_dir)"
    if [ -f "$SRC_DIR/README.md" ]; then
      if command -v glow >/dev/null 2>&1; then
        glow "$SRC_DIR/README.md"
      else
        cat "$SRC_DIR/README.md"
      fi
    else
      echo "README not found."
      exit 1
    fi
    ;;
  log-rotate)
    echo "Rotating ~/.local/share/dotfiles.log..."
    mv "$HOME/.local/share/dotfiles.log" "$HOME/.local/share/dotfiles.log.old" 2>/dev/null || true
    touch "$HOME/.local/share/dotfiles.log"
    echo "Log rotated."
    ;;
  sandbox)
    SRC_DIR="$(resolve_source_dir)"
    if [ -z "$SRC_DIR" ]; then
      echo "Dotfiles source not found."
      exit 1
    fi
    if command -v docker >/dev/null; then
      echo "Launching sandbox via Docker..."
      docker build -f "$SRC_DIR/tests/Dockerfile.sandbox" -t dotfiles-sandbox "$SRC_DIR"
      exec docker run --rm -it dotfiles-sandbox
    elif command -v podman >/dev/null; then
      echo "Launching sandbox via Podman..."
      podman build -f "$SRC_DIR/tests/Dockerfile.sandbox" -t dotfiles-sandbox "$SRC_DIR"
      exec podman run --rm -it dotfiles-sandbox
    else
      echo "Docker or Podman is required for sandbox."
      exit 1
    fi
    ;;
  heal) run_script "scripts/ops/heal.sh" "Heal script" "$@" ;;
  health | health-check) run_script "scripts/ops/health-check.sh" "Health check script" "$@" ;;
  smoke-test) run_script "scripts/diagnostics/smoke-test.sh" "Smoke test script" "$@" ;;
  verify) run_script "scripts/diagnostics/verify.sh" "Verification script" "$@" ;;
  security-score) run_script "scripts/diagnostics/security-score.sh" "Security score script" "$@" ;;
  intelligence) run_script "scripts/dot/lib/bento.sh" "Intelligence Surface" "$@" ;;
  cl | claude | gemini | kiro | sgpt | ollama | opencode | aider) run_script "scripts/dot/commands/ai.sh" "AI Bridge" "$COMMAND" "$@" ;;
  drift) run_script "scripts/diagnostics/drift-dashboard.sh" "Drift script" "$@" ;;
  chaos) run_script "scripts/ops/chaos.sh" "Chaos engineering script" "$@" ;;
  bundle) run_script "scripts/ops/bundle.sh" "Offline bundle script" "$@" ;;
  rollback) run_script "scripts/ops/rollback.sh" "Rollback script" "$@" ;;
  benchmark) run_script "scripts/tests/benchmark.sh" "Benchmark script" "$@" ;;
  load) run_script "scripts/ops/load.sh" "Load script" "$@" ;;
  tools) run_script "scripts/dot/commands/tools.sh" "Tools script" "tools" "$@" ;;
  new) run_script "scripts/dot/commands/tools.sh" "Tools script" "new" "$@" ;;
  perf)
    PERF_JSON=0
    PERF_PRECMD=0
    for arg in "$@"; do
      case "$arg" in
        --json) PERF_JSON=1 ;;
        --precmd) PERF_PRECMD=1 ;;
      esac
    done
    if [ "$PERF_JSON" = "0" ]; then
      echo "Dotfiles performance"
      echo "  DOTFILES_FAST=${DOTFILES_FAST:-0}"
      echo "  DOTFILES_ULTRA_FAST=${DOTFILES_ULTRA_FAST:-0}"
      echo "  DOTFILES_DEFER_ZINIT=${DOTFILES_DEFER_ZINIT:-1}"
      echo "  DOTFILES_ENABLE_COLORS=${DOTFILES_ENABLE_COLORS:-0}"
      echo "  DOTFILES_AI=${DOTFILES_AI:-0}"
      echo "  PRECMD_HOOKS=${PERF_PRECMD}"
    fi
    if command -v python3 >/dev/null 2>&1; then
      PERF_JSON="$PERF_JSON" PERF_PRECMD="$PERF_PRECMD" python3 - <<'PY'
import json
import os
import time

def get_status():
    status = {
        "fast": os.environ.get("DOTFILES_FAST", "0") == "1",
        "ultra_fast": os.environ.get("DOTFILES_ULTRA_FAST", "0") == "1",
        "defer_zinit": os.environ.get("DOTFILES_DEFER_ZINIT", "1") == "1",
        "ai": os.environ.get("DOTFILES_AI", "0") == "1"
    }
    return status

if os.environ.get("PERF_JSON", "0") == "1":
    print(json.dumps(get_status()))
PY
    else
      echo "  python3 not found; run: zsh -i -c exit"
    fi
    ;;
  load-bench)
    command dot-load-benchmark "$@"
    ;;
  load-bench-pty)
    command dot-load-benchmark-pty "$@"
    ;;
  ai)
    echo "AI helpers (opt-in)"
    echo "  DOTFILES_AI=${DOTFILES_AI:-0}"
    echo "  Enable: export DOTFILES_AI=1"
    if command -v ollama >/dev/null 2>&1; then
      echo "  ollama: installed"
    else
      echo "  ollama: not installed"
    fi
    if command -v llm >/dev/null 2>&1; then
      echo "  llm: installed"
    else
      echo "  llm: not installed"
    fi
    ;;
  ai-setup) run_script "scripts/ops/ai-setup.sh" "AI setup script" "$@" ;;
  ai-query) run_script "dot_local/bin/executable_dot-ai" "AI RAG script" "$@" ;;
  tune)
    SRC_DIR="$(resolve_source_dir)"
    if [ -z "$SRC_DIR" ]; then
      echo "Dotfiles source not found."
      exit 1
    fi
    if [ -f "$SRC_DIR/scripts/ops/setup.sh" ]; then
      exec bash "$SRC_DIR/scripts/ops/setup.sh" --tune
    else
      echo "Tuning script not found."
      exit 1
    fi
    ;;
  help | --help | -h)
    show_help
    ;;
  --version | -v)
    echo ".dotfiles $VERSION"
    ;;
  *)
    if [ -z "$COMMAND" ]; then
      show_help
    else
      echo "Unknown command: $COMMAND"
      echo "Try 'dot help' for usage."
      exit 1
    fi
    ;;
esac
