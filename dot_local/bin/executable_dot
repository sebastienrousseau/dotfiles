#!/usr/bin/env bash
# shellcheck disable=SC2034
# Copyright (c) 2015-2026 Dotfiles. All rights reserved.
set -euo pipefail

# Dotfiles CLI Entry Point - v0.2.496

# Ensure XDG Base Directory variables are set
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Ensure PIPX paths are set
export PIPX_HOME="${XDG_DATA_HOME}/pipx"
export PIPX_BIN_DIR="${HOME}/.local/bin"

# Ensure Nix is in PATH if installed
if [ -e "${HOME}/.nix-profile/etc/profile.d/nix.sh" ]; then
  # shellcheck disable=SC1091
  . "${HOME}/.nix-profile/etc/profile.d/nix.sh"
fi

VERSION="0.2.496"

COMMAND="${1:-}"
if [ -n "${1:-}" ]; then
  shift
fi

# Resolve source directory (needed early for ui.sh sourcing)
_resolve_source_dir() {
  local dir=""
  if [ -n "${CHEZMOI_SOURCE_DIR:-}" ] && [ -d "$CHEZMOI_SOURCE_DIR" ]; then
    dir="$CHEZMOI_SOURCE_DIR"
  elif [ -d "$HOME/.dotfiles" ]; then
    dir="$HOME/.dotfiles"
  elif [ -d "$HOME/.local/share/chezmoi" ]; then
    dir="$HOME/.local/share/chezmoi"
  elif [ -f "package.json" ] && grep -q '"name": "dotfiles"' package.json 2>/dev/null; then
    dir="$(pwd)"
  fi
  echo "$dir"
}

# Source shared UI library for consistent colors, checkmarks, and formatting.
# Falls back to minimal inline definitions if the source directory is unavailable.
_DOT_SRC="$(_resolve_source_dir)"
if [ -n "$_DOT_SRC" ] && [ -f "$_DOT_SRC/scripts/dot/lib/ui.sh" ]; then
  # shellcheck source=../../scripts/dot/lib/ui.sh
  # shellcheck disable=SC1091
  source "$_DOT_SRC/scripts/dot/lib/ui.sh"
  ui_init
else
  # Minimal fallback when source dir is not available (e.g. first install)
  # shellcheck disable=SC2034
  UI_COLOR=0
  BOLD=""
  NORMAL=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  CYAN=""
  GRAY=""
  MAGENTA=""
  ui_init() {
    if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
      UI_COLOR=1
      BASH_BOLD=$'\033[1m'
      NORMAL=$'\033[0m'
      RED=$'\033[38;5;196m'
      GREEN=$'\033[38;5;42m'
      YELLOW=$'\033[38;5;214m'
      BLUE=$'\033[38;5;63m'
      CYAN=$'\033[38;5;81m'
      GRAY=$'\033[38;5;244m'
      MAGENTA=$'\033[38;5;211m'
    fi
  }
  ui_header() {
    ui_init
    printf "\n  %s%s%s\n\n" "${BOLD}${BLUE}" "$1" "$NORMAL"
  }
  ui_section() {
    ui_init
    printf "  %s%s%s\n" "${BOLD}${CYAN}" "$1" "$NORMAL"
  }
  ui_cmd() {
    ui_init
    printf "  %s•%s %s%-16s%s %s\n" "$GREEN" "$NORMAL" "$GREEN" "$1" "$NORMAL" "$2"
  }
  ui_ok() {
    ui_init
    printf "  %s✓%s %-35s %s\n" "$GREEN" "$NORMAL" "$1" "${2:-}"
  }
  ui_info() {
    ui_init
    printf "  %s•%s %-35s %s\n" "$GRAY" "$NORMAL" "$1" "${2:-}"
  }
  ui_meta() {
    ui_init
    printf "  %s•%s %-14s %s\n" "$GRAY" "$NORMAL" "$1" "${2:-}"
  }
  ui_kv() {
    ui_init
    printf "  %s%-14s%s %s\n" "$BOLD" "$1" "$NORMAL" "$2"
  }
  ui_warn() {
    ui_init
    printf "  %s⚠%s %-35s %s\n" "$YELLOW" "$NORMAL" "$1" "${2:-}"
  }
  ui_err() {
    ui_init
    printf "  %s✗%s %-35s %s\n" "$RED" "$NORMAL" "$1" "${2:-}" >&2
  }
  ui_clear_line() { printf '\r\033[K'; }
  ui_toast() { case "$1" in success | ok) ui_ok "$2" ;; error | err) ui_err "$2" ;; warn) ui_warn "$2" ;; *) ui_info "$2" ;; esac }
fi

# Alias ui_fail → ui_err for backward compatibility in this script
ui_fail() { ui_err "$@"; }

show_help() {
  ui_header "Dotfiles CLI"
  ui_meta "Usage" "dot [command]"
  ui_meta "Version" "v$VERSION"
  echo ""

  ui_section "Core"
  ui_cmd "sync" "Apply dotfiles (--pull to fetch, --check to preview)"
  ui_cmd "add" "Add a file to chezmoi source"
  ui_cmd "diff" "Show chezmoi diff with exclusions"
  ui_cmd "status" "Show configuration drift (chezmoi status)"
  ui_cmd "edit" "Open chezmoi source in \$EDITOR"
  ui_cmd "cd" "Print source directory path (use: cd \$(dot cd))"
  ui_cmd "commit" "AI-powered conventional commit"
  echo ""

  ui_section "Diagnostics"
  ui_cmd "doctor" "System health & configuration check"
  ui_cmd "" "--heal --audit --score --smoke --drift --benchmark --json --ai"
  ui_cmd "score" "System health and security scorecard"
  ui_cmd "snapshot" "Capture baseline system snapshot"
  ui_cmd "chaos" "Simulate config corruption to test self-healing"
  ui_cmd "bundle" "Create offline archive of dotfiles environment"
  ui_cmd "rollback" "Rollback dotfiles to a previous state"
  ui_cmd "history" "Shell history analysis"
  ui_cmd "perf" "Show performance mode and quick timing"
  ui_cmd "load-bench" "Measure time to heavy-layer readiness"
  echo ""

  ui_section "AI"
  ui_cmd "ai" "AI CLI status & launcher"
  ui_cmd "ai-setup" "Interactive setup for all AI CLI tools"
  ui_cmd "ai-query" "Context-aware RAG query over your dotfiles"
  ui_cmd "cl" "Claude CLI with context patterns"
  ui_cmd "gemini" "Gemini CLI with context patterns"
  ui_cmd "kiro" "Kiro CLI with context patterns"
  ui_cmd "sgpt" "Shell-GPT with context patterns"
  ui_cmd "ollama" "Ollama with context patterns"
  ui_cmd "opencode" "OpenCode with context patterns"
  ui_cmd "aider" "Aider with context patterns"
  echo ""

  ui_section "Tools"
  ui_cmd "env" "Tool versions (mise)"
  ui_cmd "profile" "Show/switch configuration profile"
  ui_cmd "keys" "Keybindings (sign-check: verify git signing)"
  ui_cmd "tools" "Show or install nix packages"
  ui_cmd "new" "Create a new project from a template"
  ui_cmd "sandbox" "Launch a safe sandbox preview (Docker/Podman)"
  ui_cmd "lint" "Lint shell scripts (--fix to auto-format, --check for CI)"
  ui_cmd "learn" "Start the interactive tour of your new tools"
  ui_cmd "docs" "Show repo README"
  echo ""

  ui_section "Appearance"
  ui_cmd "theme" "Switch terminal theme (dark/light)"
  ui_cmd "wallpaper" "Apply a wallpaper from your library [macOS,Linux]"
  ui_cmd "fonts" "Install Nerd Fonts (JetBrainsMono by default)"
  ui_cmd "tune" "Apply OS tuning (opt-in) [macOS,Linux]"
  echo ""

  ui_section "Secrets"
  ui_cmd "secrets-init" "Initialize age key for secrets"
  ui_cmd "secrets" "Edit encrypted secrets (age)"
  ui_cmd "secrets-create" "Create an encrypted secrets file"
  ui_cmd "ssh-key" "Encrypt an SSH key locally with age"
  ui_cmd "ssh-cert" "Manage short-lived SSH certificates"
  echo ""

  ui_section "Security (opt-in)"
  ui_cmd "backup" "Create a compressed backup of your home"
  ui_cmd "encrypt-check" "Check disk encryption status"
  ui_cmd "firewall" "Apply firewall hardening [macOS,Linux]"
  ui_cmd "telemetry" "Disable OS telemetry [macOS,Linux]"
  ui_cmd "dns-doh" "Enable DNS-over-HTTPS [macOS,Linux]"
  ui_cmd "lock-screen" "Enforce lock screen idle settings [Linux]"
  ui_cmd "usb-safety" "Disable automount for removable media [Linux]"
  echo ""

  ui_section "Meta"
  ui_cmd "upgrade" "Update flake, plugins, and dotfiles"
  ui_cmd "packages" "List installed packages and package managers"
  ui_cmd "cache-refresh" "Regenerate shell caches for ultra-fast startup"
  ui_cmd "search" "Find commands by keyword"
  ui_cmd "--version" "Show version information"
  ui_cmd "help" "Show this help message"
}

resolve_source_dir() { _resolve_source_dir; }

# ─── Dispatcher ───────────────────────────────────────────────────────────────
# Routes COMMAND to the appropriate command module in scripts/dot/commands/.
# Each module receives the original COMMAND as its first argument so that its
# internal case statement can dispatch to the right sub-function.
_SOURCE_DIR="$(_resolve_source_dir)"
_CMD_DIR="${_SOURCE_DIR}/scripts/dot/commands"

_dispatch() {
  local module="$1"
  shift # remove module name; remaining $@ are the user's extra args
  local cmd_file="${_CMD_DIR}/${module}.sh"
  if [[ -f "$cmd_file" ]]; then
    # shellcheck disable=SC1090
    exec bash "$cmd_file" "$COMMAND" "$@"
  else
    ui_fail "Command module not found: $cmd_file"
    exit 1
  fi
}

case "$COMMAND" in

  # ── Core chezmoi operations ──────────────────────────────────────────────
  sync | apply | update | add | diff | status | remove | cd | edit | commit | clean-cache)
    _dispatch core "$@"
    ;;

  # ── Diagnostics ─────────────────────────────────────────────────────────
  doctor | scorecard | score | snapshot | history | perf | load-bench | load-bench-pty | \
    chaos | bundle | rollback | heal | health | health-check | smoke-test | verify | \
    security-score | drift | benchmark | intelligence | conflicts | locks | restore)
    _dispatch diagnostics "$@"
    ;;

  # ── AI tools ────────────────────────────────────────────────────────────
  ai | ai-setup | ai-query | cl | claude | gemini | kiro | sgpt | ollama | opencode | aider)
    _dispatch ai "$@"
    ;;

  # ── Tools & environment ─────────────────────────────────────────────────
  env | profile | tools | new | packages | aliases | alias-check | setup | log-rotate | lint)
    _dispatch tools "$@"
    ;;

  # ── Appearance ──────────────────────────────────────────────────────────
  theme | wallpaper | fonts | tune)
    _dispatch appearance "$@"
    ;;

  # ── Secrets ─────────────────────────────────────────────────────────────
  secrets-init | secrets | secrets-create | ssh-key | ssh-cert)
    _dispatch secrets "$@"
    ;;

  # ── Security (opt-in hardening) ──────────────────────────────────────────
  backup | encrypt-check | firewall | telemetry | dns-doh | lock-screen | usb-safety)
    _dispatch security "$@"
    ;;

  # ── Meta / housekeeping ──────────────────────────────────────────────────
  upgrade | cache-refresh | prewarm | docs | learn | keys | sandbox | mcp)
    _dispatch meta "$@"
    ;;

  # ── AI patterns (standalone script) ─────────────────────────────────────
  patterns)
    if [[ -n "$_SOURCE_DIR" ]] && [[ -f "$_SOURCE_DIR/scripts/dot/commands/patterns.sh" ]]; then
      exec bash "$_SOURCE_DIR/scripts/dot/commands/patterns.sh" "$@"
    else
      ui_fail "patterns.sh not found"
      exit 1
    fi
    ;;

  # ── Search ──────────────────────────────────────────────────────────────
  search)
    keyword="${1:-}"
    if [[ -z "$keyword" ]]; then
      echo "Usage: dot search <keyword>"
      exit 1
    fi
    show_help | grep -i --color=auto "$keyword" || echo "No commands matching '$keyword'"
    exit 0
    ;;

  # ── Help & version ──────────────────────────────────────────────────────
  help | --help | -h)
    show_help
    ;;

  --version | -v)
    ui_info "Version" ".dotfiles $VERSION"
    ;;

  "")
    show_help
    ;;

  *)
    ui_fail "Unknown command: $COMMAND"
    ui_info "Hint" "Try 'dot help' for usage"
    exit 1
    ;;
esac
