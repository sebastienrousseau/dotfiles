#!/usr/bin/env bash
# Copyright (c) 2015-2026 Dotfiles. All rights reserved.
set -euo pipefail

# Dotfiles CLI Entry Point - v0.2.496

# Ensure XDG Base Directory variables are set
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Ensure PIPX paths are set
export PIPX_HOME="${XDG_DATA_HOME}/pipx"
export PIPX_BIN_DIR="${HOME}/.local/bin"

# Ensure Nix is in PATH if installed
if [ -e "${HOME}/.nix-profile/etc/profile.d/nix.sh" ]; then
  # shellcheck disable=SC1091
  . "${HOME}/.nix-profile/etc/profile.d/nix.sh"
fi

VERSION="0.2.496"

COMMAND="${1:-}"
if [ -n "${1:-}" ]; then
  shift
fi

# Resolve source directory (needed early for ui.sh sourcing)
_resolve_source_dir() {
  local dir=""
  if [ -n "${CHEZMOI_SOURCE_DIR:-}" ] && [ -d "$CHEZMOI_SOURCE_DIR" ]; then
    dir="$CHEZMOI_SOURCE_DIR"
  elif [ -d "$HOME/.dotfiles" ]; then
    dir="$HOME/.dotfiles"
  elif [ -d "$HOME/.local/share/chezmoi" ]; then
    dir="$HOME/.local/share/chezmoi"
  elif [ -f "package.json" ] && grep -q '"name": "dotfiles"' package.json 2>/dev/null; then
    dir="$(pwd)"
  fi
  echo "$dir"
}

# Source shared UI library for consistent colors, checkmarks, and formatting.
# Falls back to minimal inline definitions if the source directory is unavailable.
_DOT_SRC="$(_resolve_source_dir)"
if [ -n "$_DOT_SRC" ] && [ -f "$_DOT_SRC/scripts/dot/lib/ui.sh" ]; then
  # shellcheck source=../../scripts/dot/lib/ui.sh
  # shellcheck disable=SC1091
  source "$_DOT_SRC/scripts/dot/lib/ui.sh"
  ui_init
else
  # Minimal fallback when source dir is not available (e.g. first install)
  # shellcheck disable=SC2034
  UI_COLOR=0; BOLD=""; NORMAL=""; RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; GRAY=""; MAGENTA=""
  ui_init() {
    if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
      # shellcheck disable=SC2034
      UI_COLOR=1; BASH_BOLD=$'\033[1m'; NORMAL=$'\033[0m'
      # shellcheck disable=SC2034
      RED=$'\033[38;5;196m'; GREEN=$'\033[38;5;42m'; YELLOW=$'\033[38;5;214m'
      # shellcheck disable=SC2034
      BLUE=$'\033[38;5;63m'; CYAN=$'\033[38;5;81m'; GRAY=$'\033[38;5;244m'; MAGENTA=$'\033[38;5;211m'
    fi
  }
  ui_header()  { ui_init; printf "\n  %s%s%s\n\n" "${BOLD}${BLUE}" "$1" "$NORMAL"; }
  ui_section() { ui_init; printf "  %s%s%s\n" "${BOLD}${CYAN}" "$1" "$NORMAL"; }
  ui_cmd()     { ui_init; printf "  %s•%s %s%-16s%s %s\n" "$GREEN" "$NORMAL" "$GREEN" "$1" "$NORMAL" "$2"; }
  ui_ok()      { ui_init; printf "  %s✓%s %-35s %s\n" "$GREEN" "$NORMAL" "$1" "${2:-}"; }
  ui_info()    { ui_init; printf "  %s•%s %-35s %s\n" "$GRAY" "$NORMAL" "$1" "${2:-}"; }
  ui_meta()    { ui_init; printf "  %s•%s %-14s %s\n" "$GRAY" "$NORMAL" "$1" "${2:-}"; }
  ui_kv()      { ui_init; printf "  %s%-14s%s %s\n" "$BOLD" "$1" "$NORMAL" "$2"; }
  ui_warn()    { ui_init; printf "  %s⚠%s %-35s %s\n" "$YELLOW" "$NORMAL" "$1" "${2:-}"; }
  ui_err()     { ui_init; printf "  %s✗%s %-35s %s\n" "$RED" "$NORMAL" "$1" "${2:-}" >&2; }
  ui_clear_line() { printf '\r\033[K'; }
  ui_toast()   { case "$1" in success|ok) ui_ok "$2";; error|err) ui_err "$2";; warn) ui_warn "$2";; *) ui_info "$2";; esac; }
fi

# Alias ui_fail → ui_err for backward compatibility in this script
ui_fail() { ui_err "$@"; }

