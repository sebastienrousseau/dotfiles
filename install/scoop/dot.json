{
  "$comment": [
    "Scoop manifest scaffold for the `dot` CLI from",
    "https://github.com/sebastienrousseau/dotfiles",
    "",
    "STATUS: scaffold only. The framework does not yet ship a",
    "single-tarball release artefact (chezmoi-managed root layout).",
    "The v0.2.503 reorganisation (docs/operations/ROADMAP_V0_2_503.md)",
    "produces a standalone-CLI tarball that this manifest can",
    "point at. Until then, the hash/url fields are PLACEHOLDER.",
    "",
    "Publication target: sebastienrousseau/scoop-bucket repo.",
    "Validate via:  scoop install https://raw.githubusercontent.com/sebastienrousseau/scoop-bucket/master/dot.json"
  ],
  "version": "0.2.503",
  "description": "Declarative dotfiles CLI for macOS, Linux, WSL, and PowerShell.",
  "homepage": "https://github.com/sebastienrousseau/dotfiles",
  "license": "MIT",
  "depends": ["chezmoi"],
  "suggest": {
    "gum": "charm/gum",
    "starship": "main/starship"
  },
  "architecture": {
    "64bit": {
      "url": "https://github.com/sebastienrousseau/dotfiles/releases/download/v0.2.503/dot-0.2.503-windows-amd64.zip",
      "hash": "sha256:PLACEHOLDER_FILL_ON_v0.2.503_PUBLICATION"
    },
    "arm64": {
      "url": "https://github.com/sebastienrousseau/dotfiles/releases/download/v0.2.503/dot-0.2.503-windows-arm64.zip",
      "hash": "sha256:PLACEHOLDER_FILL_ON_v0.2.503_PUBLICATION"
    }
  },
  "bin": ["dot.ps1", "dot.cmd"],
  "checkver": "github",
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/sebastienrousseau/dotfiles/releases/download/v$version/dot-$version-windows-amd64.zip"
      },
      "arm64": {
        "url": "https://github.com/sebastienrousseau/dotfiles/releases/download/v$version/dot-$version-windows-arm64.zip"
      }
    }
  }
}
