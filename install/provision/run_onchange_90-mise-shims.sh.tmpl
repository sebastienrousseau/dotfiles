#!/usr/bin/env bash

# run_onchange_90-mise-shims.sh.tmpl
# This script ensures that all mise shims are linked to ~/.local/bin
# It runs whenever the mise configuration changes.
# Hash of mise config: {{ include "dot_config/mise/config.toml" | sha256sum }}

set -euo pipefail

# Ensure the sync script is in the PATH or call it directly
# Since we just added it to ~/.local/bin via chezmoi, it might not be applied yet
# but the script itself is in the source tree.
# We call it from the expected installed location.

if [ -x "$HOME/.local/bin/mise-sync" ]; then
    "$HOME/.local/bin/mise-sync"
else
    # Fallback if not yet linked by chezmoi
    "{{ .chezmoi.sourceDir }}/dot_local/bin/executable_mise-sync"
fi
