#!/usr/bin/env bash
# Copyright (c) 2015-2026 Dotfiles. All rights reserved.
set -euo pipefail

OS="$(uname -s)"
ARCH="$(uname -m)"

case "$OS" in
  Darwin) target_os="darwin" ;;
  Linux) target_os="linux" ;;
  *)
    echo "Unsupported OS: $OS" >&2
    exit 1
    ;;
esac

case "$ARCH" in
  x86_64 | amd64) target_arch="x86_64" ;;
  arm64 | aarch64) target_arch="aarch64" ;;
  *)
    echo "Unsupported arch: $ARCH" >&2
    exit 1
    ;;
esac

BASE_URL="https://desktop-release.q.us-east-1.amazonaws.com"

if [[ "$target_os" == "darwin" ]]; then
  app_path="/Applications/Kiro CLI.app/Contents/MacOS"

  if [[ ! -x "$app_path/kiro-cli" ]]; then
    if ! command -v brew >/dev/null 2>&1; then
      echo "Kiro CLI.app not found and Homebrew is unavailable." >&2
      exit 1
    fi

    if brew list --cask kiro-cli >/dev/null 2>&1; then
      brew upgrade --cask kiro-cli
    else
      brew install --cask kiro-cli
    fi
  fi

  mkdir -p "$ASDF_DOWNLOAD_PATH/kirocli/bin"
  cp "$app_path/kiro-cli" "$ASDF_DOWNLOAD_PATH/kirocli/bin/"
  cp "$app_path/kiro-cli-chat" "$ASDF_DOWNLOAD_PATH/kirocli/bin/"
  cp "$app_path/kiro-cli-term" "$ASDF_DOWNLOAD_PATH/kirocli/bin/"
  exit 0
fi

# Linux
# Check for musl (simplified check)
if ldd /bin/ls 2>&1 | grep -q musl; then
  filename="kirocli-${target_arch}-linux-musl.zip"
else
  filename="kirocli-${target_arch}-linux.zip"
fi

download_url="${BASE_URL}/latest/$filename"

echo "Downloading Kiro CLI from $download_url..."
curl -fsSL -o "$ASDF_DOWNLOAD_PATH/kiro-cli.zip" "$download_url"
unzip -q "$ASDF_DOWNLOAD_PATH/kiro-cli.zip" -d "$ASDF_DOWNLOAD_PATH"
rm "$ASDF_DOWNLOAD_PATH/kiro-cli.zip"
