#!/usr/bin/env bash
# Copyright (c) 2015-2026 Dotfiles. All rights reserved.
## mkscript — Create a ready-to-go shell script.
##
## # Usage
##   mkscript hello
##   mkscript /tmp/myscript

set -euo pipefail

file="${1:-}"

usage() {
  echo "Usage: mkscript <path>" >&2
}

case "$file" in
  -h | --help)
    usage
    exit 0
    ;;
  "")
    usage
    exit 1
    ;;
  -*)
    printf 'Unknown option: %s\n' "$file" >&2
    usage
    exit 2
    ;;
esac

if [[ -z "${file}" ]]; then
  usage
  exit 1
fi

if [[ -f "${file}" ]]; then
  echo "${file} already exists, aborting." >&2
  exit 1
fi

mkdir -p "$(dirname "${file}")"

cat >"${file}" <<'EOF'
#!/usr/bin/env bash
# Copyright (c) 2015-2026 Dotfiles. All rights reserved.

set -euo pipefail

echo "hello world"
EOF

chmod +x "${file}"
echo "Created ${file}"
