#!/usr/bin/env bash
set -euo pipefail

# Measure time to load heavy layers in a fresh interactive shell
# Usage: dot-load-benchmark [runs]

usage() {
  echo "Usage: dot-load-benchmark [runs]"
  echo "  runs: positive integer number of benchmark runs (default: 5)"
}

case "${1:-}" in
  -h | --help)
    usage
    exit 0
    ;;
  -*)
    printf 'Unknown option: %s\n' "$1" >&2
    usage >&2
    exit 2
    ;;
esac

RUNS=${1:-5}
if ! [[ "$RUNS" =~ ^[1-9][0-9]*$ ]]; then
  printf 'Invalid runs value: %s\n' "$RUNS" >&2
  usage >&2
  exit 2
fi

TOTAL=0

printf "dot load benchmark (runs=%s)\n" "$RUNS"

for i in $(seq 1 "$RUNS"); do
  ms=$(zsh -i -c '
    zmodload zsh/datetime
    if (( ${+functions[_dotfiles_load_heavy_layers]} )); then
      t0=$EPOCHREALTIME
      _dotfiles_load_heavy_layers
      t1=$EPOCHREALTIME
      echo $(( (t1 - t0) * 1000.0 ))
    else
      echo 0
    fi
  ' 2>/dev/null)
  printf "  run %s: %0.1f ms\n" "$i" "$ms"
  TOTAL=$(awk -v a="$TOTAL" -v b="$ms" 'BEGIN {print a+b}')

done

AVG=$(awk -v total="$TOTAL" -v n="$RUNS" 'BEGIN {print total/n}')

echo "avg: ${AVG} ms"
