#!/usr/bin/env bash
# Copyright (c) 2015-2026 Dotfiles. All rights reserved.
## rec-stop — Restore shell history after recording.
##
## # Usage
##   rec-stop

set -euo pipefail

# Restore all backed-up history files (bounded: max 3 candidates)
candidates=(
  "${HISTFILE:-${HOME}/.bash_history}"
  "${HOME}/.local/share/fish/fish_history"
  "${HOME}/.bash_history"
)

restored=0
for histfile in "${candidates[@]}"; do
  if [[ -f "${histfile}.bak" ]]; then
    if mv "${histfile}.bak" "${histfile}"; then
      echo "  Restored: ${histfile}"
      restored=$((restored + 1))
    else
      echo "  Failed to restore: ${histfile}" >&2
    fi
  fi
done

if [[ $restored -eq 0 ]]; then
  echo "No backups found, nothing to restore."
  exit 0
fi

echo ""
echo "Recording mode OFF ($restored files restored)"
