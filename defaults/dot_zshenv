# XDG Base Directory Specification
export XDG_CONFIG_HOME="${HOME}/.config"
export XDG_CACHE_HOME="${HOME}/.cache"
export XDG_DATA_HOME="${HOME}/.local/share"
export XDG_STATE_HOME="${HOME}/.local/state"

# Minimal early PATH: ~/.local/bin only (ensures `dot` CLI is available before .zshrc loads)
# Full PATH assembly is handled in dot_config/shell/00-core-paths.sh.tmpl (sourced by .zshrc)
if [[ -d "${HOME}/.local/bin" ]]; then
  [[ ":${PATH}:" != *":${HOME}/.local/bin:"* ]] && export PATH="${HOME}/.local/bin:${PATH}"
fi

# Homebrew (macOS ARM)
if [[ -d "/opt/homebrew/bin" ]]; then
  [[ ":${PATH}:" != *":/opt/homebrew/bin:"* ]] && export PATH="/opt/homebrew/bin:${PATH}"
fi

# Zsh
export ZDOTDIR="${XDG_CONFIG_HOME}/zsh"

# Dotfiles cockpit opt-in — enables the run_onchange_25-build-dot-ai-tui
# hook so ~/.local/bin/dot-ai-tui is (re)built by chezmoi apply.
export DOTFILES_AI=1

# Tools
export CURL_HOME="${XDG_CONFIG_HOME}/curl"
export WGETRC="${XDG_CONFIG_HOME}/wget/wgetrc"
export GEMRC="${XDG_CONFIG_HOME}/gem/gemrc"
export NANORC="${XDG_CONFIG_HOME}/nano/nanorc"

# Vim (Use VIMINIT to source the config file)
# Use single quotes to prevent shell expansion (Vim will expand $XDG_CONFIG_HOME)
# export VIMINIT='source $XDG_CONFIG_HOME/vim/vimrc'

# SSH agent — point shells at the systemd user agent socket when available.
# Linux only; macOS uses its own keychain integration via ssh-add --apple-use-keychain.
if [[ -z "${SSH_AUTH_SOCK:-}" ]] && [[ -n "${XDG_RUNTIME_DIR:-}" ]] \
  && [[ -S "${XDG_RUNTIME_DIR}/ssh-agent.socket" ]]; then
  export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR}/ssh-agent.socket"
fi

# Nix
if [ -e "${HOME}/.nix-profile/etc/profile.d/nix.sh" ]; then
  . "${HOME}/.nix-profile/etc/profile.d/nix.sh"
fi
