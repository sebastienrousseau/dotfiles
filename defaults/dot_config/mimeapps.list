[Default Applications]
# Browser
text/html=google-chrome.desktop
x-scheme-handler/http=google-chrome.desktop
x-scheme-handler/https=google-chrome.desktop
x-scheme-handler/about=google-chrome.desktop
x-scheme-handler/unknown=google-chrome.desktop

# File manager
inode/directory=thunar.desktop

# Video
video/mp4=mpv.desktop
video/x-matroska=mpv.desktop
video/webm=mpv.desktop
video/quicktime=mpv.desktop
video/x-msvideo=mpv.desktop
video/x-flv=mpv.desktop
video/mpeg=mpv.desktop
video/ogg=mpv.desktop
video/3gpp=mpv.desktop

# Audio
audio/flac=mpv.desktop
audio/mp3=mpv.desktop
audio/mp4=mpv.desktop
audio/mpeg=mpv.desktop
audio/ogg=mpv.desktop
audio/opus=mpv.desktop
audio/wav=mpv.desktop
audio/webm=mpv.desktop
audio/x-flac=mpv.desktop
audio/x-m4a=mpv.desktop
audio/x-vorbis+ogg=mpv.desktop

# Images
image/avif=mpv.desktop
image/bmp=mpv.desktop
image/gif=mpv.desktop
image/heic=mpv.desktop
image/jpeg=mpv.desktop
image/png=mpv.desktop
image/svg+xml=mpv.desktop
image/tiff=mpv.desktop
image/webp=mpv.desktop

# Text / Code → Neovim
application/javascript=nvim.desktop
application/json=nvim.desktop
application/toml=nvim.desktop
application/x-sh=nvim.desktop
application/xml=nvim.desktop
text/css=nvim.desktop
text/javascript=nvim.desktop
text/markdown=nvim.desktop
text/plain=nvim.desktop
text/x-c++src=nvim.desktop
text/x-csrc=nvim.desktop
text/x-go=nvim.desktop
text/x-java=nvim.desktop
text/x-log=nvim.desktop
text/x-makefile=nvim.desktop
text/x-python=nvim.desktop
text/x-ruby=nvim.desktop
text/x-rust=nvim.desktop
text/x-shellscript=nvim.desktop
text/x-yaml=nvim.desktop

# Documents
application/pdf=org.pwmt.zathura.desktop
application/epub=org.pwmt.zathura.desktop

# Archives
application/zip=xarchiver.desktop
application/x-7z-compressed=xarchiver.desktop
application/x-gzip=xarchiver.desktop
application/x-tar=xarchiver.desktop
