{{- $fontFamily := default "JetBrainsMono Nerd Font" .terminal_font_family -}}
{{- $fontSize := default 20 .terminal_font_size -}}
{{- $linuxDesktop := or .features.linux_desktop .features.niri -}}

font_family {{ $fontFamily }}
{{- if eq .chezmoi.os "darwin" }}
bold_font SF Mono Bold
italic_font SF Mono Regular Italic
bold_italic_font SF Mono Bold Italic
{{- else }}
symbol_map U+E000-U+F8FF Symbols Nerd Font
{{- end }}
font_size {{ $fontSize }}

window_padding_width 16
background_opacity {{ if eq .chezmoi.os "darwin" }}0.92{{ else }}0.96{{ end }}
dim_opacity 0.75
confirm_os_window_close 0
enable_audio_bell no
cursor_trail 0
{{- if $linuxDesktop }}
linux_display_server wayland
{{- end }}

{{- /* The terminal always uses the DARK palette, in both OS light and dark
       modes: the engineered dark scheme is high-contrast and low-fatigue,
       whereas a very light (cream) terminal bg washes out faint/secondary text.
       The wallpaper and the rest of the desktop still follow the OS mode. */ -}}
{{- $themeName := default "big-sur-dark" .theme -}}
{{- $family := trimSuffix "-dark" (trimSuffix "-light" $themeName) -}}
{{- $t := index .themes (printf "%s-dark" $family) -}}
{{- if not $t -}}{{- $t = index .themes $themeName -}}{{- end -}}
{{- if not $t -}}{{- $t = index .themes "big-sur-dark" -}}{{- end }}
background {{ $t.term.bg }}
foreground {{ $t.term.fg }}
selection_background {{ $t.term.sel_bg }}
selection_foreground {{ $t.term.sel_fg }}
cursor {{ $t.term.cursor }}

color0  {{ $t.term.c0 }}
color1  {{ $t.term.c1 }}
color2  {{ $t.term.c2 }}
color3  {{ $t.term.c3 }}
color4  {{ $t.term.c4 }}
color5  {{ $t.term.c5 }}
color6  {{ $t.term.c6 }}
color7  {{ $t.term.c7 }}
color8  {{ $t.term.c8 }}
color9  {{ $t.term.c9 }}
color10 {{ $t.term.c10 }}
color11 {{ $t.term.c11 }}
color12 {{ $t.term.c12 }}
color13 {{ $t.term.c13 }}
color14 {{ $t.term.c14 }}
color15 {{ $t.term.c15 }}
