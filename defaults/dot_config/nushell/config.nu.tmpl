# Yazi integration to cd on quit
def --env yy [...args] {
	let tmp = (mktemp -t "yazi-cwd.XXXXXX")
	yazi ...$args --cwd-file $tmp
	let cwd = (open $tmp)
	if $cwd != "" and $cwd != $env.PWD {
		cd $cwd
	}
	rm -fp $tmp
}

# Pueue Background Task Wrappers (Nushell Style)
def silent-run [cmd: string] {
    pueue add -- $cmd
}

def notify-run [cmd: string] {
    let task_id = (pueue add --print-id -- $cmd)
    echo $"Task ($task_id) submitted: ($cmd)"
    # Nu doesn't have background shells like bash, but we can call bash
    bash -c $"pueue wait ($task_id) && echo 'âœ… Task ($task_id) finished: ($cmd)' &"
}

def bg-upgrade [] {
    echo "ðŸš€ Starting background upgrades..."
    if (which brew | length) > 0 { silent-run "brew upgrade" }
    if (which nix | length) > 0 { silent-run "nix flake update" }
    silent-run "chezmoi update"
    echo "Check status with 'pueue status'"
}

