# Define basic environment variables
$env.HOSTNAME = (sys host | get hostname)
$env.OS_ARCH = (sys host | get arch)
$env.OS_NAME = (sys host | get name)
$env.USER_LANGUAGE = "en_GB.UTF-8"
$env.DOTFILES_VERSION = '{{ .dotfiles_version }}'
# Dotfiles cockpit opt-in â€” enables run_onchange_25-build-dot-ai-tui so
# ~/.local/bin/dot-ai-tui is (re)built by chezmoi apply.
$env.DOTFILES_AI = "1"
$env.LANG = $env.USER_LANGUAGE
$env.TERM = "xterm-256color"

# Editor / pager â€” parity with the zsh/bash profile (nvim â†’ vim â†’ vi).
$env.EDITOR = (if (which nvim | is-not-empty) { "nvim" } else if (which vim | is-not-empty) { "vim" } else { "vi" })
$env.VISUAL = $env.EDITOR
$env.PAGER = "less"

# Path setup: Nushell handles paths as a list in $env.PATH
let paths = [
    $"($env.HOME)/.local/bin",
    $"($env.HOME)/bin",
    "/opt/homebrew/bin",
    "/opt/homebrew/sbin",
    $"($env.HOME)/.cargo/bin",
    $"($env.HOME)/go/bin",
    $"($env.HOME)/.bun/bin",
    "/usr/local/bin",
    "/usr/bin",
    "/bin",
    "/usr/sbin",
    "/sbin"
]

$env.PATH = ($env.PATH | split row (char esep) | append $paths | uniq)

# Setup shell tool integrations.
#
# The `_cached_eval` module (loaded via dot_config/nushell/cached_eval.nu)
# adds mtime-based cache invalidation so we don't spawn `starship init
# nu` / `mise activate nu` / etc. on every shell start. Closes the
# Nushell parity AC of #880.
mkdir ~/.cache/nushell

use ~/.config/nushell/cached_eval.nu *

# The empty-file fallbacks preserve the `source` targets in
# config.nu.tmpl â€” Nushell parses sources at parse time and refuses
# to start if any source path is missing.

if (_cached_eval_path_or_skip starship init nu | str length) == 0 {
    "" | save -f ~/.cache/nushell/starship.nu
} else {
    cp (_cached_eval starship init nu) ~/.cache/nushell/starship.nu
}

if (_cached_eval_path_or_skip zoxide init nushell | str length) == 0 {
    "" | save -f ~/.cache/nushell/zoxide.nu
} else {
    cp (_cached_eval zoxide init nushell) ~/.cache/nushell/zoxide.nu
}

if (_cached_eval_path_or_skip atuin init nu | str length) == 0 {
    "" | save -f ~/.cache/nushell/atuin.nu
} else {
    cp (_cached_eval atuin init nu) ~/.cache/nushell/atuin.nu
}

# Generate Nushell alias cache from bash alias library
do -i {
    bash --norc --noprofile -c '
        source "$HOME/.config/shell/90-ux-aliases.sh" 2>/dev/null
        source "$HOME/.config/shell/91-ux-aliases-lazy.sh" 2>/dev/null
        alias -p 2>/dev/null | while IFS= read -r line; do
            name="${line#alias }"
            name="${name#-- }"
            name="${name%%=*}"
            # Only valid Nushell identifiers (letters, digits, hyphens, underscores)
            [[ "$name" =~ ^[a-zA-Z_][a-zA-Z0-9_-]*$ ]] || continue
            val="${line#*=}"
            # Remove surrounding single quotes from bash alias output
            val="${val#\'}"
            val="${val%\'}"
            # Skip syntax incompatible with Nushell aliases
            case "$val" in
                *\$\{*|*\$\(*) continue ;;
                *\`*) continue ;;
                *"[["*|*"&&"*|*"||"*) continue ;;
                *";"*|*"|"*) continue ;;
                *">"*|*"<"*) continue ;;
                *"("*|*")"*) continue ;;
                "") continue ;;
            esac
            printf "alias %s = %s\n" "$name" "$val"
        done
    ' | save -f ~/.cache/nushell/bash-aliases.nu
}
# Carapace multi-shell completions
if (which carapace | length) > 0 {
    carapace _carapace nushell | save -f ~/.cache/nushell/carapace.nu
} else {
    "" | save -f ~/.cache/nushell/carapace.nu
}

# Ensure alias cache exists even if bash bridge failed
if not ($"($env.HOME)/.cache/nushell/bash-aliases.nu" | path exists) {
    "" | save -f ~/.cache/nushell/bash-aliases.nu
}
