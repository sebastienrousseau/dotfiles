{{- $root := . -}}
{{- $groupsPath := joinPath $root.chezmoi.sourceDir ".chezmoitemplates/functions/groups.json" -}}
{{- $groups := (fromJson (include $groupsPath)) -}}
{{- $fishFuncsPattern := joinPath $root.chezmoi.sourceDir "dot_config/fish/functions/*.fish" -}}
{{- $fishFuncs := glob $fishFuncsPattern -}}
# Fish function wrappers (Generated by Chezmoi)
# Delegates to bash function library in ~/.config/shell/50-logic-functions.sh
# Edit .chezmoitemplates/functions/ source files, not this file.

if status is-interactive
{{- range $group, $files := $groups }}
{{- range $files }}
{{- $func := trimSuffix ".sh" (base .) }}
{{- $nativePath := joinPath $root.chezmoi.sourceDir (printf "dot_config/fish/functions/%s.fish" $func) }}
{{- if not (has $nativePath $fishFuncs) }}
    function {{ $func }} --description 'Dotfiles: {{ $func }}'
        bash -c 'source "$HOME/.config/shell/50-logic-functions.sh" 2>/dev/null; {{ $func }} "$@"' -- $argv
    end
{{- end }}
{{- end }}
{{- end }}
end
