{{- $fishFuncsPattern := joinPath .chezmoi.sourceDir "dot_config/fish/functions/*.fish" -}}
{{- $fishFuncs := glob $fishFuncsPattern -}}
# Fish aliases — bridged from bash alias library (Generated by Chezmoi)
# Edit .chezmoitemplates/aliases/ source files, not this file.
#
# Data flow: .chezmoitemplates/aliases/ -> 90/91-ux-aliases*.sh -> bash bridge -> cache

if status is-interactive
    set -l _cache_dir "$HOME/.cache/fish"
    set -l _alias_cache "$_cache_dir/bash-aliases.fish"
    set -l _src_eager "$HOME/.config/shell/90-ux-aliases.sh"
    set -l _src_lazy "$HOME/.config/shell/91-ux-aliases-lazy.sh"

    # Native fish functions that must not be overridden by bash aliases
    set -l _skip{{ range $fishFuncs }} {{ trimSuffix ".fish" (base .) }}{{ end }}

    # Rebuild cache when alias sources change or cache is missing / stale.
    # A cache still using the old `alias name=value` format (v0) is also
    # treated as stale so upgrading users pick up the abbr-based cache
    # without needing to nuke it manually.
    set -l _stale 0
    if not test -f "$_alias_cache"
        set _stale 1
    else if test -f "$_src_eager"; and test "$_src_eager" -nt "$_alias_cache"
        set _stale 1
    else if test -f "$_src_lazy"; and test "$_src_lazy" -nt "$_alias_cache"
        set _stale 1
    else if not head -n 1 "$_alias_cache" 2>/dev/null | string match -qr '^abbr --add '
        set _stale 1
    end

    if test "$_stale" = 1
        mkdir -p "$_cache_dir"
        # Source bash aliases, filter fish-incompatible syntax, write cache
        env -i HOME="$HOME" PATH="$PATH" bash --norc --noprofile -c '
            source "$HOME/.config/shell/90-ux-aliases.sh" 2>/dev/null
            source "$HOME/.config/shell/91-ux-aliases-lazy.sh" 2>/dev/null
            alias -p 2>/dev/null | while IFS= read -r line; do
                name="${line#alias }"
                name="${name#-- }"
                name="${name%%=*}"
                [[ "$name" =~ ^[a-zA-Z_][a-zA-Z0-9_.-]*$ ]] || continue
                val="${line#*=}"
                # Skip bash-specific syntax incompatible with fish
                case "$val" in
                    *\$\{*) continue ;;
                    *"; then "*) continue ;;
                    *"[[ "*) continue ;;
                    *\`*) continue ;;
                esac
                printf "abbr --add %s -- %s\n" "$name" "$val"
            done
        ' 2>/dev/null | while read -l _line
            set -l _parts (string match -r '^abbr --add (\S+) -- ' -- "$_line")
            set -l _name
            if set -q _parts[2]
                set _name $_parts[2]
            end
            set -l _target (string replace -r '^abbr --add \S+ -- ["'\'']?([^ "'\'']+).*$' '$1' -- "$_line")
            if set -q _name[1]; and not contains -- "$_name" $_skip
                if string match -rq '^dot_[a-z0-9_]+$' -- "$_target"
                    continue
                end
                echo "$_line"
            end
        end >"$_alias_cache.tmp"
        mv "$_alias_cache.tmp" "$_alias_cache"
    end

    # Source cached aliases
    if test -s "$_alias_cache"
        source "$_alias_cache"
    end

    # Remove stale alias wrappers that reference bash-only helper functions.
    if functions -q cat; and not functions -q dot_cat
        set -l _cat_def (functions cat)
        if string match -rq 'dot_cat \$argv' -- "$_cat_def"
            functions -e cat
        end
    end
end
