# Performance optimization - skip if not interactive
status is-interactive; or return

# Only source once
if set -q FISH_CONFIG_SOURCED
    return
end
set -g FISH_CONFIG_SOURCED 1

{{- /* Input Validation: Ensure crucial variables are set */ -}}
{{- if not .chezmoi.homeDir -}}
  {{- fail "Critical Error: .chezmoi.homeDir is not set!" -}}
{{- end -}}

# Load local customizations if they exist
if test -f "$HOME/.config/fish/config.fish.local"
    source "$HOME/.config/fish/config.fish.local"
end

# Ensure LS_COLORS is set for fish (bridged from bash dircolors setup)
if not set -q LS_COLORS
    set -l _dircolors_cache "$HOME/.cache/shell/dircolors.sh"
    if test -f "$_dircolors_cache"
        # Extract LS_COLORS value from cached dircolors output
        set -l _val (string match -r "LS_COLORS='([^']+)'" < "$_dircolors_cache")
        if set -q _val[2]
            set -gx LS_COLORS "$_val[2]"
        end
    else if command -q dircolors
        set -gx LS_COLORS (dircolors -c 2>/dev/null | string match -r "LS_COLORS='([^']+)'" | tail -1)
    else if test (uname -s) = "Darwin"
        set -gx CLICOLOR 1
        set -gx LSCOLORS "ExFxCxDxBxegedabagacad"
    end
end

# Welcome message
set -g fish_greeting ""
