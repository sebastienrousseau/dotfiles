# 🅳🅾🆃🅵🅸🅻🅴🆂 (v{{ .dotfiles_version }}) - Task Runner
# <https://dotfiles.io>

# Default task: list all commands
default:
    @just --list

# Apply dotfiles configuration
apply:
    chezmoi apply --force

# Update dependencies and tools
update:
    topgrade

# -----------------------------------------------------------------------------
# Maintenance
# -----------------------------------------------------------------------------

# Clean package cache and orphaned packages (Arch/CachyOS)
clean:
    sudo pacman -Rns $(pacman -Qdtq) || true
    paccache -r

# -----------------------------------------------------------------------------
# WebAssembly (Wasm) Tools
# -----------------------------------------------------------------------------

# Compile the Rust system utility to Wasm (with hardware-native optimizations)
wasm-build:
    cd lib/wasm-tools && RUSTFLAGS="-C target-cpu=native" cargo build --target wasm32-wasi --release
    mkdir -p dot_local/bin/wasm
    cp lib/wasm-tools/target/wasm32-wasi/release/dot-sys.wasm dot_local/bin/wasm/dot-sys.wasm

# Run the compiled Wasm tool
wasm-run:
    wasmtime dot_local/bin/wasm/dot-sys.wasm

# -----------------------------------------------------------------------------
# Secrets & Security
# -----------------------------------------------------------------------------

# Encrypt a secret file using SOPS
encrypt-secret secret_path:
    sops --encrypt --in-place {{ "{{" }}secret_path{{ "}}" }}

# Decrypt a secret file using SOPS
decrypt-secret secret_path:
    sops --decrypt --in-place {{ "{{" }}secret_path{{ "}}" }}
