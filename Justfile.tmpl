# 🅳🅾🆃🅵🅸🅻🅴🆂 (v{{ .dotfiles_version }}) - Task Runner
# <https://dotfiles.io>

# Default task: list all commands
default:
    @just --list

# Apply dotfiles configuration
apply:
    chezmoi apply --force

# Run the full reliability audit
test:
    bash ./scripts/qa/reliability-audit.sh

# Run the quick local gate
test-quick:
    bash ./scripts/qa/reliability-audit.sh --quick

# Update dependencies and tools
update:
    topgrade

# -----------------------------------------------------------------------------
# Maintenance
# -----------------------------------------------------------------------------

# Clean package cache and orphaned packages (Arch/CachyOS)
clean:
    sudo pacman -Rns $(pacman -Qdtq) || true
    paccache -r

# -----------------------------------------------------------------------------
# Secrets & Security
# -----------------------------------------------------------------------------

# Encrypt a secret file using SOPS
encrypt-secret secret_path:
    sops --encrypt --in-place {{ "{{" }}secret_path{{ "}}" }}

# Decrypt a secret file using SOPS
decrypt-secret secret_path:
    sops --decrypt --in-place {{ "{{" }}secret_path{{ "}}" }}
