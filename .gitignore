# Dotfiles - gitignore
# v0.2.500

# Locally built Go binaries (dot-ai-tui is built to ~/.local/bin via run_onchange)
defaults/dot_local/share/dot-ai-tui/dot-ai-tui
defaults/dot_local/share/dot-ui/dot-ui
# Go coverage profiles from local test runs
defaults/dot_local/share/*/cov.out

# OS Artifacts
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.Trash-*
Thumbs.db
ehthumbs.db
Desktop.ini

# Archives
*.tgz
*.tar.gz
*.zip

# Editors
.vscode/
.idea/
*.swp
*~

# Logs
*.log
logs/

# Build/Dist
dist/
build/
debug/
lib/wasm-tools/target/

# Node (Partial support for scripts)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# pnpm content-addressable store (should never appear in the tree; if a tool
# drops one here by accident, keep it out of commits).
.pnpm-store/

# AI-assistant local state
# .claude/ holds per-machine Claude Code settings (e.g. settings.local.json
# permission allowlists). Machine-specific — not for version control.
# The repo-wide CLAUDE.md at the root IS tracked; only the .claude/ state dir is not.
.claude/

# Chezmoi
.chezmoitemplates/**/.DS_Store

# Secrets / local environment (never pushed)
.env
.env.*
!.env.example
.history

# Version-sync backups (timestamped, not needed in repo)
.version-sync-backup/

# Machine-specific configs (local only, never pushed)
dot_etc/machines/
install/provision/run_onchange_60-macbookair9-1-zorinos.sh.tmpl
_build/

# Coverage artifacts
/coverage/
.sass-cache/

# Runtime upgrade-report output
/nightly-reports/
.cache/

# Local security-audit script output
.security-audit.log

# AI-agent dotfiles regenerated by `dot agents render` from CLAUDE.md.
# The canonical source is CLAUDE.md (tracked); these derivatives are
# rendered on contribute (post-clone) so the repo root stays uncluttered.
.aider.conf.yml
.clinerules
.continuerc.json
.codex/
.cursor/
.gemini/
.jules/
.roo/
.windsurf/
.zed/

# MkDocs Material build output
/site/
