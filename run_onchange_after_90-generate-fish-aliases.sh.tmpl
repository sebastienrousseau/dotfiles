#!/usr/bin/env bash

# Hash of the alias definitions so this runs when they change
# hash: {{ include "dot_config/shell/90-ux-aliases.sh.tmpl" | sha256sum }}

# This script implements the "Autoloading" paradigm for Fish shell.
set -euo pipefail

FISH_FUNCS_DIR="${HOME}/.config/fish/functions"
ALIASES_FILE="${HOME}/.config/shell/90-ux-aliases.sh"

# Ensure the functions directory exists
mkdir -p "$FISH_FUNCS_DIR"

# Check if the aliases file exists
if [[ ! -f "$ALIASES_FILE" ]]; then
    exit 0
fi

# Parse the aliases file and generate fish functions
grep '^alias ' "$ALIASES_FILE" | while read -r line; do
    # Strip 'alias ' prefix
    definition="${line#alias }"
    
    # Split into name and command (first '=' delimiter)
    name="${definition%%=*}"
    cmd="${definition#*=}"
    
    # Clean up the command (remove surrounding quotes)
    cmd=$(echo "$cmd" | sed -e "s/^'//" -e "s/'$//" -e 's/^"//' -e 's/"$//')
    
    # Skip invalid or unsafe names
    if [[ -z "$name" || "$name" == *" "* || "$name" == *"/"* ]]; then
        continue
    fi
    
    # Write the autoloaded function
    # We use a heredoc to create the function file
    cat <<EOF > "${FISH_FUNCS_DIR}/${name}.fish"
# Autogenerated from ~/.config/shell/90-ux-aliases.sh
function ${name} --wraps="${cmd%% *}" --description "alias ${name}=${cmd}"
    ${cmd} \$argv
end
EOF
done

# Ensure explicit shims for fish
cat <<'EOF' > "$FISH_FUNCS_DIR/l.fish"
function l --wraps=ls --description 'List contents of directory'
    if command -v eza >/dev/null 2>&1
        eza --sort Name --icons --group-directories-first $argv
    else
        ls $argv
    end
end
EOF

cat <<'EOF' > "$FISH_FUNCS_DIR/ll.fish"
function ll --wraps=ls --description 'List contents of directory in long format'
    if command -v eza >/dev/null 2>&1
        eza -alF --sort Name --icons --group-directories-first $argv
    else
        ls -lA $argv
    end
end
EOF

cat <<'EOF' > "$FISH_FUNCS_DIR/la.fish"
function la --wraps=ls --description 'List contents of directory including hidden files'
    if command -v eza >/dev/null 2>&1
        eza -a --sort Name --icons --group-directories-first $argv
    else
        ls -a $argv
    end
end
EOF

cat <<'EOF' > "$FISH_FUNCS_DIR/lt.fish"
function lt --wraps=ls --description 'List contents of directory in tree format'
    if command -v eza >/dev/null 2>&1
        eza -aT --sort Name --icons --group-directories-first $argv
    else
        ls -R $argv
    end
end
EOF
