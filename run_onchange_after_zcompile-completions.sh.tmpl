#
# run_onchange_after_zcompile-completions.sh.tmpl
#
# Pre-compile every `.zsh` file in the shell completion corpus so zsh
# picks up the bytecode `.zwc` form directly (avoids re-parsing on
# every shell start). Runs once per chezmoi apply when any of the
# tracked completion/template sources change.
#
# Tracked hashes (drive the run_onchange contract):
#   completion fragments: {{ output "find" .chezmoi.sourceDir "-type" "f" "-path" "*/completions/*.zsh" | sha256sum }}
#   zshrc:                {{ include "dot_config/zsh/dot_zshrc.tmpl" | sha256sum }}
#   options:              {{ include "dot_config/zsh/rc.d/30-options.zsh.tmpl" | sha256sum }}
#
# Skip-rules:
#   * Skipped on non-darwin / non-linux platforms.
#   * Skipped if `zsh` itself is not on PATH (servers / minimal images).
#   * Skipped under `DOTFILES_SKIP_ZCOMPILE=1` for CI runs that don't
#     need on-disk bytecode.
#
# Refs: #864

set -euo pipefail

if [[ "${DOTFILES_SKIP_ZCOMPILE:-0}" == "1" ]]; then
  echo "[zcompile] skipped (DOTFILES_SKIP_ZCOMPILE=1)" >&2
  exit 0
fi

if ! command -v zsh >/dev/null 2>&1; then
  echo "[zcompile] skipped (zsh not on PATH)" >&2
  exit 0
fi

# User-managed completion source dirs (subset of fpath). Per-machine
# package-manager dirs (Homebrew, /usr/local/share/zsh) are left alone
# because the package manager already manages their .zwc lifecycle.
declare -a fpath_roots=(
  "${HOME}/.local/share/zsh/completions"
)

compiled=0
skipped=0
for root in "${fpath_roots[@]}"; do
  [[ -d "$root" ]] || continue
  while IFS= read -r -d '' f; do
    zwc="${f}.zwc"
    # Skip if the .zwc is already current.
    if [[ -f "$zwc" && "$zwc" -nt "$f" ]]; then
      skipped=$((skipped + 1))
      continue
    fi
    if zsh -c "zcompile '$f'" 2>/dev/null; then
      compiled=$((compiled + 1))
    fi
  done < <(find "$root" -type f \( -name "_*" -o -name "*.zsh" \) -print0 2>/dev/null)
done

echo "[zcompile] compiled=$compiled skipped=$skipped" >&2
