{{- /*
  Warp theme generated from the active dotfiles theme.

  Deployed to: ~/.warp/themes/dotfiles.yaml on every chezmoi apply.
  Pick "dotfiles" in Warp Settings -> Appearance -> Themes.

  Schema reference: https://docs.warp.dev/appearance/custom-themes
*/ -}}
{{- $t := index .themes (default "macos-monterey-dark" .theme) -}}
{{- if not $t -}}{{- $t = index .themes "macos-monterey-dark" -}}{{- end }}
{{- $tt := $t -}}
{{- $themeName := default "macos-monterey-dark" .theme -}}
{{- if hasSuffix "-light" $themeName -}}
  {{- $darkTheme := index .themes (printf "%s-dark" (trimSuffix "-light" $themeName)) -}}
  {{- if $darkTheme -}}{{- $tt = $darkTheme -}}{{- end -}}
{{- end -}}
{{- $details := "darker" -}}
{{- if eq $t.mode "light" -}}{{- $details = "lighter" -}}{{- end }}
# Active dotfiles theme: {{ $themeName }}
# Regenerated by chezmoi apply.
accent: '{{ $tt.ui.accent }}'
background: '{{ $tt.term.bg }}'
foreground: '{{ $tt.term.fg }}'
details: '{{ $details }}'
terminal_colors:
  normal:
    black:   '{{ $tt.term.c0 }}'
    red:     '{{ $tt.term.c1 }}'
    green:   '{{ $tt.term.c2 }}'
    yellow:  '{{ $tt.term.c3 }}'
    blue:    '{{ $tt.term.c4 }}'
    magenta: '{{ $tt.term.c5 }}'
    cyan:    '{{ $tt.term.c6 }}'
    white:   '{{ $tt.term.c7 }}'
  bright:
    black:   '{{ $tt.term.c8 }}'
    red:     '{{ $tt.term.c9 }}'
    green:   '{{ $tt.term.c10 }}'
    yellow:  '{{ $tt.term.c11 }}'
    blue:    '{{ $tt.term.c12 }}'
    magenta: '{{ $tt.term.c13 }}'
    cyan:    '{{ $tt.term.c14 }}'
    white:   '{{ $tt.term.c15 }}'
